{
  "jest": {
    "moduleMapping": {
      "pattern": "moduleNameMapping.*found",
      "description": "Fix Jest moduleNameMapping -> moduleNameMapper",
      "priority": "critical",
      "fix": {
        "type": "replaceInFile",
        "file": "jest.config.js",
        "search": "moduleNameMapping",
        "replace": "moduleNameMapper"
      }
    },
    "multipleConfigs": {
      "pattern": "Multiple configurations found.*jest\\.config",
      "description": "Remove duplicate Jest configurations",
      "priority": "critical",
      "fix": {
        "type": "custom",
        "action": "removeDuplicateJestConfigs"
      }
    }
  },
  "react": {
    "cacheError": {
      "pattern": "cache.*is not a function",
      "description": "Fix React cache mock for Jest",
      "priority": "critical",
      "fix": {
        "type": "ensureInFile",
        "file": "tests/setup.js",
        "content": "jest.mock('react', () => ({\n  ...jest.requireActual('react'),\n  cache: jest.fn((fn) => fn)\n}));"
      }
    }
  },
  "syntax": {
    "duplicateDeclaration": {
      "pattern": "Identifier '([^']+)' has already been declared",
      "description": "Fix duplicate variable declarations",
      "priority": "critical",
      "fix": {
        "type": "custom",
        "action": "removeDuplicateDeclarations"
      }
    },
    "unexpectedToken": {
      "pattern": "SyntaxError.*Unexpected token",
      "description": "Fix syntax errors",
      "priority": "critical",
      "fix": {
        "type": "custom",
        "action": "fixSyntaxError"
      }
    }
  },
  "typescript": {
    "anyType": {
      "pattern": "implicitly has an 'any' type",
      "description": "Fix TypeScript any types",
      "priority": "medium",
      "fix": {
        "type": "custom",
        "action": "addTypeAnnotations"
      }
    },
    "missingProperty": {
      "pattern": "Property '([^']+)' does not exist on type",
      "description": "Fix missing property errors",
      "priority": "critical",
      "fix": {
        "type": "custom",
        "action": "fixPropertyAccess"
      }
    },
    "unknownType": {
      "pattern": "'([^']+)' is of type 'unknown'",
      "description": "Fix unknown type errors",
      "priority": "critical",
      "fix": {
        "type": "custom",
        "action": "addTypeAssertion"
      }
    },
    "indexTypeError": {
      "pattern": "Type '\\{\\}' cannot be used as an index type",
      "description": "Fix index type errors",
      "priority": "critical",
      "fix": {
        "type": "custom",
        "action": "fixIndexAccess"
      }
    },
    "typeNotAssignable": {
      "pattern": "Type '([^']+)' is not assignable to type '([^']+)'",
      "description": "Fix type assignment errors",
      "priority": "high",
      "fix": {
        "type": "custom",
        "action": "fixTypeAssignment"
      }
    }
  },
  "testing": {
    "mockNotDefined": {
      "pattern": "mock.*is not defined",
      "description": "Fix test mocking setup",
      "priority": "high",
      "fix": {
        "type": "custom",
        "action": "fixTestMocking"
      }
    },
    "testExpectation": {
      "pattern": "expect\\(received\\)\\.toContain\\(expected\\)",
      "description": "Fix test expectations",
      "priority": "low",
      "fix": {
        "type": "custom",
        "action": "updateTestExpectations"
      }
    }
  },
  "build": {
    "missingModule": {
      "pattern": "Module not found.*Can't resolve",
      "description": "Fix missing module imports",
      "priority": "critical",
      "fix": {
        "type": "custom",
        "action": "fixMissingModules"
      }
    },
    "buildError": {
      "pattern": "Build failed|Failed to compile",
      "description": "Fix build compilation errors",
      "priority": "critical",
      "fix": {
        "type": "custom",
        "action": "fixBuildErrors"
      }
    }
  },
  "eslint": {
    "warnings": {
      "pattern": "warning.*eslint",
      "description": "Fix ESLint warnings",
      "priority": "medium",
      "fix": {
        "type": "custom",
        "action": "fixEslintWarnings"
      }
    },
    "errors": {
      "pattern": "error.*eslint",
      "description": "Fix ESLint errors",
      "priority": "high",
      "fix": {
        "type": "custom",
        "action": "fixEslintErrors"
      }
    }
  }
}
