# See https://help.github.com/(articles)/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.vscode

# debug
logs*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prevent bloat accumulation (Phase 3 cleanup automation)
# Deployment logs (should be archived automatically)
vercel-deployment-*.json
deployment-monitoring-report*.json

# Test result files (auto-archived after 30 days)
tests/*-results.json
tests/*-report.json

# Backup files (should be in archive/ directory)
*.backup
*backup*
backup-*/

# Temporary build artifacts
.cache/
*.tmp
*.temp
.temp/
