    "geist": "^1.3.1",
    "next": "^15.1.3",
    "next-mdx-remote": "^4.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sugar-high": "^0.6.0",
    "typescript": "5.3.3"
  },
