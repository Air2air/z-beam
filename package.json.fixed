    "lint:components": "npm run enforce-components",
    "create:component": "node safe-component-creation.js",
    "setup:enforcement": "./setup-enforcement.sh",
    "validate:guide": "./validate-project-guide.sh",
    "check:claude-compliance": "./.githooks/claude-compliance"
  },
  "dependencies": {
