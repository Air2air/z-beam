      "frequency": {
        "min": 1,
        "max": 200,
        "value": 30,
        "unit": "kHz",
        "description": "Typical 10-100 kHz for pulsed cleaning; higher rates increase speed but risk heat accumulation on alumina (trade-off: >50 kHz may cause microcracks). 30 kHz recommended for safe operation. Source: Academic literature in Appl. Surf. Sci. by Lorenz et al. (2009) on repetition rate effects in oxide cleaning."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "value": 20,
        "description": "Nanosecond regime (5-100 ns) preferred for cost-effective cleaning; picosecond (ps) or femtosecond (fs) for ultra-minimal HAZ but less common industrially. 20 ns recommended to limit thermal diffusion in low-conductivity alumina. Source: Laser physics research in Opt. Express by Colombier et al. (2012) on ceramic ablation thresholds."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "value": 2000,
        "unit": "mm/s",
        "description": "Effective range for contaminant removal without excessive heat buildup; slower for heavy contamination (500-1000 mm/s), faster for light (3000-5000 mm/s). Recommended 2000 mm/s for optimal balance on alumina. Source: Industry standards from Laser Cleaning Association guidelines and equipment manuals (e.g., Adapt Laser Systems)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass (2-5) for heavy layers; 2 passes recommended for complete removal on alumina without risking brittleness-induced damage. Source: Industry practice in case studies from Laser Institute of America reports on ceramic surface preparation."
      },
