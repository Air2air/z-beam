        "unit": "μm",
        "description": "Beam diameter range for industrial cleaning; smaller (0.5-1 mm) for detailed work, larger (2-5 mm) for broad brick surfaces. Recommended 2 mm for uniform coverage on rough brick texture. Source: Equipment specifications from Coherent and Trumpf laser systems for surface preparation; optimized in process studies (Lasers in Engineering, 2019)."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 30,
        "unit": "kHz",
        "description": "Typical for pulsed cleaning to control energy delivery; 10-50 kHz for brick prevents heat accumulation in low-conductivity material, while higher rates speed up process but risk thermal stress. Recommended 30 kHz for optimal throughput. Source: Academic literature in Optics Express (2014) on pulse repetition effects in cultural heritage cleaning; trade-off noted in manufacturer manuals (e.g., Adapt Laser Systems)."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "value": 20,
        "description": "Nanosecond regime (5-100 ns) preferred for brick to ablate contaminants via photothermal effects with minimal heat-affected zone (HAZ); picosecond (ps) or femtosecond (fs) reduces HAZ further but increases cost. Recommended 20 ns for balance. Source: Laser physics research in Applied Surface Science (2017) on stone ablation thresholds; avoids fs due to brick's high damage risk from shockwaves."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "value": 500,
        "unit": "mm/s",
        "description": "Effective speeds for contaminant removal on porous brick; slower (100-500 mm/s) for heavy soiling like soot, faster (500-2000 mm/s) for light dust. Recommended 500 mm/s optimizes cleaning rate while minimizing heat buildup. Source: Industry standards from Laser Cleaning Europe guidelines; case studies in Journal of Cultural Heritage (2018) on brick restoration."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass (2-5) for heavy layers to ensure complete removal without excessive energy. Recommended 2 passes for brick to achieve uniform results while staying below damage threshold. Source: Industry practice in restoration case studies (e.g., European Commission reports on laser cleaning of masonry, 2020); avoids overexposure on porous surfaces."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 60,
        "unit": "%",
        "description": "Overlap ensures uniform coverage on uneven brick; 30-50% for speed, 60-80% for thorough cleaning of pores. Recommended 60% for optimal uniformity without redundancy. Source: Process optimization studies in Applied Optics (2015) on scan strategies for stone; standard in manufacturer guidelines (e.g., Laserax equipment manuals)."
