    "machineSettings": {
      "laserPower": {
        "description": "Optimal average power for Gallium oxide removal without excessive melting",
        "unit": "W",
        "value": 45,
        "min": 1.0,
        "max": 120
      },
      "wavelength": {
        "description": "Near-IR wavelength for moderate Gallium absorption with good penetration",
        "unit": "nm",
        "value": 1064,
        "min": 355,
        "max": 10640
      },
      "spotSize": {
        "min": 0.1,
        "max": 500,
        "unit": "μm",
        "value": 500,
        "description": "Typical beam diameter for industrial cleaning; smaller (200-400 μm) for fine details on Ga surfaces (e.g., electronics prep), larger (500-800 μm) for broad areas. 500 μm recommended for uniform coverage without excessive heat concentration. Source: Equipment specs from Trumpf and CleanLaser systems for 1064 nm cleaners; adapted for delicate substrates like Ga."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "unit": "kHz",
        "value": 20,
        "description": "Typical for industrial cleaning to achieve high throughput; 20 kHz recommended for Gallium to avoid heat accumulation (high freq increases overlap heating, risky for low mp); lower rates for heavy contamination. Trade-off: higher rate speeds process but risks melting. Source: Academic literature (e.g., J. Laser Appl., 2018 on pulse train effects in metals); generalized for Ga."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "description": "Nanosecond regime preferred for Gallium to ablate contaminants via photothermal effects while minimizing heat-affected zone (HAZ); picosecond/femtosecond for ultra-precise but less common industrially due to cost. Value 20 ns balances efficiency and low thermal damage. Source: Laser physics research on metal ablation (e.g., Appl. Phys. A, 2015 on ns/ps cleaning); conservative for Ga's low mp.",
        "value": 500
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1000,
        "description": "Range for effective contaminant ablation on metals; slower for heavy contamination (200-500 mm/s), faster for light (1000-3000 mm/s) to minimize heat input on thermally conductive Gallium (40.6 W/m·K). Recommended 1000 mm/s for optimal balance. Source: Industry standards from IPG Photonics and Coherent manuals for 1064 nm systems; adapted for low-melt metals."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "unit": "passes",
        "value": 2,
        "description": "Single pass for light contamination, multi-pass (2-4) for heavy oxides on Gallium; 2 passes recommended for complete removal while limiting total energy input to prevent melting. Source: Industry case studies on metal surface prep (e.g., Proc. SPIE, 2019); practical for Ga based on low thermal tolerance, uncertainty in specific Ga trials."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "unit": "%",
        "description": "Standard range for uniform scan coverage in laser cleaning; 50% recommended for Gallium to ensure even contaminant removal without gaps or excessive overlap heating (high conductivity aids dissipation but low mp limits intensity). Source: Process optimization studies (e.g., J. Clean. Prod., 2021 on scan strategies); typical 30-80% adjusted conservatively for metals.",
        "value": 50.0
      }
