      "spotSize": {
        "min": 0.1,
        "max": 500,
        "unit": "μm",
        "value": 200,
        "description": "Typical beam diameter for precise industrial cleaning; smaller (100-200 μm) for fine details, larger (300-500 μm) for broad areas. 200 μm recommended for uniform Chromium surface preparation. Source: Equipment specifications from Coherent and Trumpf laser systems; process guidelines in ILSC standards."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 50,
        "unit": "kHz",
        "description": "Typical 10-100 kHz for pulsed cleaning; higher rates increase speed but risk heat accumulation on reflective Chromium. 50 kHz recommended for efficient coverage without overheating. Trade-off: high freq accelerates process but requires monitoring. Source: Academic literature in Optics Express (2021) on repetition rate effects in laser ablation."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime (5-100 ns) standard for industrial cleaning to ablate contaminants with minimal HAZ; picosecond (ps) or femtosecond (fs) for ultra-precise work but less common industrially. 20 ns recommended for Chromium to limit thermal diffusion. Source: Laser physics research in Applied Surface Science (2019) on pulse regimes for metals."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "value": 1500,
        "unit": "mm/s",
        "description": "Effective range for contamination removal; slower for heavy oxides (500-1000 mm/s), faster for light contaminants (2000-5000 mm/s). Recommended 1500 mm/s for optimal balance on Chromium's high thermal conductivity. Source: Industry standards from Laserax equipment manuals; case studies in Journal of Cleaner Production (2020)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass (2-5) for heavy layers; 2 passes recommended for complete removal on Chromium without excessive exposure. Source: Industry practice in case studies from Laser Cleaning International reports and Applied Optics (2020)."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 60,
        "unit": "%",
        "description": "Typical 30-80% for uniform coverage and to avoid gaps/striping; 60% recommended for even energy distribution on Chromium's conductive surface. Source: Process optimization studies in Lasers in Manufacturing and Materials Processing (2019)."
      }
