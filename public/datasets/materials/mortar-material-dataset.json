        "value": 50,
        "unit": "kHz",
        "description": "Typical for pulsed 1064 nm systems on mortar to achieve pulse overlap without excessive heat accumulation; higher rates speed up cleaning but risk thermal damage on porous mortar. 50 kHz balances speed and safety. Source: Academic literature, e.g., Appl. Surf. Sci. (2019) on stone heritage cleaning trade-offs."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "value": 30,
        "description": "Nanosecond regime preferred for cost-effective cleaning of mortar; 30 ns minimizes heat-affected zone (HAZ) due to mortar's low thermal diffusivity (~0.5 mm²/s). Picosecond (ps) or femtosecond optional for precision but less common industrially. Source: Laser physics research in Opt. Lasers Eng. (2015) on ablation of cementitious substrates."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "value": 1500,
        "unit": "mm/s",
        "description": "Effective speeds balance removal efficiency and heat input; slower for heavy contamination (e.g., paint), faster for light dirt. Recommended 1500 mm/s for uniform mortar surface prep. Source: Industry standards from Laser Cleaning Europe guidelines and equipment manuals (e.g., Adapt Laser Systems)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass for heavy layers on mortar to prevent over-ablation. Recommended 2 passes for complete removal while preserving substrate integrity. Source: Industry case studies, e.g., restoration projects in Constr. Build. Mater. (2020)."
      },
