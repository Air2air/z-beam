      "frequency": {
        "min": 1,
        "max": 200,
        "value": 20,
        "unit": "kHz",
        "description": "Typical for industrial cleaning; 20 kHz balances speed and heat accumulation on reflective SiGe surfaces (absorptivity ~0.4 at 1064 nm); higher rates risk buildup, lower for heavy cleaning. Source: Academic literature in J. Phys. D: Appl. Phys. (2021) on pulse train effects in semiconductor processing."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime preferred for cost-effective cleaning with minimal HAZ on SiGe; picosecond (ps) for ultra-precision but less common industrially. 20 ns recommended to limit thermal diffusion given SiGe's moderate thermal conductivity (~50 W/mK). Source: Laser physics research in Appl. Phys. A (2019) on pulsed laser ablation of Ge alloys."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 500,
        "description": "Effective for contamination removal; slower (100-500 mm/s) for heavy contaminants, faster (1000-2000 mm/s) for light; 500 mm/s optimal for SiGe to balance efficiency and heat control. Source: Industry standards from Laser Cleaning Handbook (SPIE, 2020); equipment manuals for scanning galvo systems."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass (2-5) for heavy; 2 passes typical for SiGe to ensure complete removal while minimizing cumulative damage. Source: Industry case studies in Proc. SPIE (2022) on laser cleaning of semiconductor substrates."
      },
