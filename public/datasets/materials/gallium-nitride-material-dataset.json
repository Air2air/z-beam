      "frequency": {
        "min": 1,
        "max": 200,
        "value": 50,
        "unit": "kHz",
        "description": "50 kHz balances speed and heat management for GaN; higher rates risk accumulation on low-absorptivity material, slower for precision. Trade-off: faster cleaning but potential thermal damage. Source: Academic literature (Appl. Surf. Sci. 2020 on pulsed laser cleaning of GaN)."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 10,
        "unit": "ps",
        "description": "Picosecond preferred over ns for minimal HAZ on reflective GaN (reflectivity ~40% at 1064 nm); avoids thermal accumulation. Femtosecond possible but less common industrially. Source: Laser physics research (Opt. Express 2018 on ultrashort pulse cleaning of nitrides)."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1000,
        "description": "Effective for light contaminants at higher speeds, slower for heavy; 1000 mm/s optimal for uniform GaN surface prep without overheating. Range from industry standards for 1064 nm cleaning. Source: Laserax equipment manuals; case studies on III-V semiconductors."
