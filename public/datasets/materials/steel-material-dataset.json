      "spotSize": {
        "min": 0.1,
        "max": 500,
        "value": 250,
        "unit": "μm",
        "description": "Beam diameter range; smaller (100-300 μm) for precision surface prep, larger (500-1000 μm) for broad area cleaning. Recommended 250 μm for uniform steel cleaning, balancing resolution and coverage. Source: Equipment specs from Adapt Laser Systems and Coherent Inc. manuals."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 80,
        "unit": "kHz",
        "description": "Typical for pulsed cleaning; lower rates (20-50 kHz) reduce heat accumulation, higher (100-200 kHz) speed up process but risk overheating steel. Recommended 80 kHz for balanced throughput on metals. Trade-off: High freq increases fluence overlap. Source: Academic literature in Optics and Lasers in Engineering (2019)."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime (5-200 ns) dominant for cost-effective cleaning; picosecond (ps) or femtosecond for ultra-low HAZ but less common industrially. Recommended 20 ns minimizes thermal effects on steel while ablating contaminants. Source: Laser physics research in Applied Surface Science (2018) on ablation thresholds."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1500,
        "description": "Effective range for contamination removal; slower (100-500 mm/s) for heavy rust/oil, faster (2000-5000 mm/s) for light oxides. Recommended 1500 mm/s balances cleaning efficiency and heat dissipation on reflective steel surfaces. Source: Industry standards from Laserax equipment manuals and studies in Journal of Cleaner Production (2020)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass (2-5) for heavy layers like mill scale. Recommended 2 passes for complete removal on steel without excessive heat input. Source: Industry case studies in Surface and Coatings Technology (2021) and practical guidelines from Laser Cleaning Europe."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 60,
        "unit": "%",
        "description": "Ensures uniform coverage; 30-50% for speed, 70-80% for thorough cleaning. Recommended 60% prevents gaps on irregular steel surfaces while minimizing over-processing. Source: Process optimization in International Journal of Advanced Manufacturing Technology (2022)."
      }
