        "description": "Smaller spots for fine detail on terracotta artifacts, larger for broad industrial areas; 200 μm recommended for balanced resolution and coverage on uneven surfaces. Source: Equipment specs from Coherent and Trumpf laser systems."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 20,
        "unit": "kHz",
        "description": "Typical for 1064 nm cleaning to achieve good overlap without excessive heat buildup; higher rates speed up process but risk accumulation on porous terracotta. 20 kHz balances speed and safety. Source: Academic literature on pulsed laser cleaning (e.g., Pouli et al., 2010, Spectrochim. Acta B)."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 15,
        "unit": "ns",
        "description": "Nanosecond regime preferred for terracotta to minimize heat-affected zone (HAZ) while ablating contaminants; picosecond (ps) or femtosecond (fs) for ultra-precision but less common industrially. 15 ns optimal for low thermal conductivity materials. Source: Laser ablation research (e.g., Anisimov et al., 2015, Appl. Phys. A)."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1500,
        "description": "Effective speeds balance cleaning efficiency and heat input; slower for heavy contamination (500-1000 mm/s), faster for light (2000-3000 mm/s). Recommended 1500 mm/s for uniform terracotta surface preparation. Source: Industry manuals from IPG Photonics and Laserax equipment guidelines."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light soiling, multi-pass for heavy contamination; 2 passes typical for complete terracotta cleaning without overexposure. Source: Case studies in cultural heritage laser cleaning (e.g., Radvan et al., 2007, Lasers in the Conservation of Artworks)."
      },
