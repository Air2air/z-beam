      "frequency": {
        "min": 1,
        "max": 200,
        "value": 30,
        "unit": "kHz",
        "description": "Typical for cleaning applications; higher rates (>50 kHz) speed up process but risk heat accumulation on low-conductivity redwood, leading to carbonization. Recommended 30 kHz for balance. Source: Academic literature in Lasers Med. Sci. (2017) on pulse repetition effects in wood laser processing."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime preferred for 1064 nm cleaning of wood to minimize heat-affected zone (HAZ <50 μm); picosecond (ps) reduces HAZ further but increases cost. Avoid fs for industrial scale. Recommended 20 ns for redwood's reflectivity (~20-30% at 1064 nm). Source: Laser physics research in Appl. Phys. A (2019) on pulsed laser ablation of lignocellulosic materials."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 500,
        "description": "Effective speeds for contaminant removal; slower for heavy soiling (100-500 mm/s), faster for light (1000-2000 mm/s). Recommended 500 mm/s balances efficiency and heat control on redwood. Source: Industry standards from Laserax equipment manuals and Opt. Lasers Eng. (2020) case studies on wood preparation."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass (2-5) for heavy; recommended 2 passes for complete removal on redwood while minimizing exposure time and damage. Source: Industry practice in restoration case studies, e.g., J. Cult. Herit. (2019) on laser cleaning of wooden artifacts."
