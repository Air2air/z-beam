        "unit": "μm",
        "description": "Beam diameter range for precision vs. area coverage; smaller for fine surface prep on Neodymium components (e.g., magnets), larger for broad cleaning. 200 μm recommended for uniform energy distribution without hotspots. Source: Equipment specifications from Trumpf laser systems; process optimization in Surface and Coatings Technology (2022)."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 30,
        "unit": "kHz",
        "description": "Typical for pulsed Nd:YAG cleaning; higher rates speed up process but risk heat accumulation on low-conductivity Neodymium, potentially causing melting. 30 kHz recommended for efficient, controlled energy delivery. Source: Academic literature in Optics Express (2021) on repetition rate trade-offs for metallic substrates; manufacturer data from Coherent Inc."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime preferred for cost-effective cleaning with minimal heat-affected zone (HAZ) on heat-sensitive Neodymium; picosecond (ps) or femtosecond (fs) reduce HAZ further but increase cost. 20 ns recommended for balancing ablation and substrate integrity. Source: Laser physics research in Applied Surface Science (2019) on pulse duration effects for metal cleaning; avoids fs due to overkill for industrial apps."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "value": 1500,
        "unit": "mm/s",
        "description": "Effective speeds for contaminant removal on reflective metals; slower for heavy contamination (e.g., oxides), faster for light rust/oils. Recommended 1500 mm/s optimizes cleaning without excessive heat buildup on Neodymium. Source: Industry standards from Laserax equipment manuals; case studies in Journal of Cleaner Production (2020) for rare earth metals."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass for heavy layers to ensure complete removal without cumulative damage to soft Neodymium. 2 passes recommended for industrial surface preparation. Source: Industry practice in laser cleaning case studies, e.g., SPIE Proceedings (2020) on metallic alloys; adapts to Neodymium's reactivity."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 50,
        "unit": "%",
        "description": "Ensures uniform coverage and prevents gaps in cleaning; 50% optimal for Neodymium to minimize overexposure while achieving even fluence distribution. Higher for detailed work. Source: Process optimization studies in Lasers in Manufacturing and Materials Processing (2019); standard in equipment like Adapt Laser guidelines."
