      "spotSize": {
        "min": 0.1,
        "max": 500,
        "value": 200,
        "unit": "μm",
        "description": "Typical beam diameters for precise industrial cleaning; smaller for fine details, larger for broad areas. Recommended 200 μm for Gneiss to ensure uniform coverage on textured surfaces. Source: Equipment specifications from Coherent and Trumpf lasers for stone applications."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "unit": "kHz",
        "value": 50,
        "description": "Typical for pulsed 1064 nm lasers in cleaning; higher rates speed up process but risk heat accumulation on reflective, low-conductivity Gneiss (reflectivity ~20-30% at 1064 nm). Recommended 50 kHz for efficient cleaning without thermal damage. Source: Academic literature in J. Laser Appl. (2021) on rock surface preparation."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime preferred for Gneiss cleaning to ablate contaminants with minimal heat-affected zone (HAZ); picosecond (ps) or femtosecond (fs) reduce HAZ further but increase cost—ns sufficient for industrial use. Recommended 20 ns avoids excessive heat buildup in low-conductivity Gneiss. Source: Laser physics research in Appl. Surf. Sci. (2019) on stone ablation thresholds."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1500,
        "description": "Range for effective contaminant removal on rocky surfaces; slower for heavy contamination (e.g., rust or oils), faster for light dust. Recommended 1500 mm/s for optimal balance on Gneiss to prevent overheating. Source: Industry standards from Laserax manuals; case studies on granite-like materials in Opt. Lasers Eng. (2020)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass for heavy layers; recommended 2 passes for complete removal on Gneiss without risking substrate erosion. Source: Industry practice in cultural heritage cleaning case studies (e.g., granite analogs) from Restaurators (2019); adaptable to industrial."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 60,
        "unit": "%",
        "description": "Ensures uniform coverage; 60% recommended for Gneiss to avoid gaps on irregular surfaces while minimizing over-processing and heat buildup. Typical range from process optimization. Source: Studies in Laser Ablation and Surf. Process. (2022) on optimizing scan patterns for stones."
      }
