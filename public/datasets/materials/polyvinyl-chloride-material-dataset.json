      "spotSize": {
        "min": 0.1,
        "max": 500,
        "unit": "μm",
        "value": 150,
        "description": "Beam diameter for effective coverage; smaller (50-100 μm) for fine details, larger (200-300 μm) for broad areas; 150 μm recommended for uniform PVC surface preparation without pinpoint damage. Source: Equipment specifications from Coherent and Trumpf laser systems for industrial cleaning."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 30,
        "unit": "kHz",
        "description": "Typical for pulsed cleaning; 20-50 kHz recommended for PVC to achieve fast processing while limiting heat accumulation from low reflectivity (~5-10% at 1064 nm); higher rates increase speed but risk thermal buildup. Source: Academic literature in Optics Express (2021) on repetition rate effects in polymer laser cleaning."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 30,
        "unit": "ns",
        "description": "Nanosecond regime preferred for industrial cleaning of polymers to minimize heat-affected zone (HAZ); picosecond (ps) or femtosecond for ultra-precision but costlier; 30 ns optimal for PVC to enable photothermal ablation without excessive melting. Source: Laser physics research in Applied Surface Science (2019) on polymer thresholds; avoids fs/ps due to equipment availability."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1000,
        "description": "Effective for contamination removal without overheating; slower (500-1000 mm/s) for heavy contamination, faster (2000-3000 mm/s) for light; recommended 1000 mm/s balances efficiency and safety for PVC's poor thermal conductivity. Source: Industry standards from Laser Cleaning Europe guidelines; case studies in Journal of Cleaner Production (2020)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass (2-4) for heavy; 2 passes recommended for complete PVC cleaning to ensure removal without cumulative heat damage. Source: Industry practice in case studies from Surface and Coatings Technology (2022); avoids excessive passes due to PVC's heat sensitivity."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 50,
        "unit": "%",
        "description": "Ensures uniform coverage without gaps or over-ablation; 50% optimal for PVC to prevent uneven heating and maintain surface integrity during scanning. Source: Process optimization studies in Lasers in Manufacturing and Materials Processing (2020); typical 30-80% range for polymer applications."
      }
