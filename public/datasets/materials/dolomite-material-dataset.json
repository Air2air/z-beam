      "spotSize": {
        "min": 0.1,
        "max": 500,
        "unit": "μm",
        "value": 200,
        "description": "Beam diameter for precise vs. broad cleaning; smaller for fine details on dolomite surfaces (100-200 μm), larger for areas (300-500 μm). 200 μm recommended for uniform preparation. From equipment specs in Laserax and SPI Lasers systems for industrial stone applications."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "unit": "kHz",
        "value": 50,
        "description": "Typical for 1064 nm cleaning to balance speed and heat; higher rates (50-100 kHz) enable faster processing but risk accumulation in low-thermal-conductivity dolomite. 50 kHz recommended for safe operation. From academic literature like Journal of Applied Physics on pulse train effects in stone ablation."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "value": 20,
        "description": "Nanosecond regime preferred for cost-effective cleaning of dolomite; picosecond (ps) or femtosecond for ultra-minimal HAZ but less common industrially. 20 ns recommended to limit heat diffusion in low-conductivity dolomite. Supported by laser physics research in Optics & Lasers in Engineering (e.g., ns pulses reduce thermal effects in carbonates)."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1500,
        "description": "Effective speeds for 1064 nm cleaning of dolomite; slower for heavy contamination (500-1000 mm/s), faster for light (2000-5000 mm/s). Recommended 1500 mm/s for optimal contaminant removal with minimal passes. From industry standards in laser cleaning manuals (e.g., Adapt Laser Systems) and studies on stone surface preparation."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "unit": "passes",
        "value": 2,
        "description": "Single pass for light contamination, multi-pass (2-5) for heavy; 2 passes recommended for complete removal on dolomite without over-ablation. Drawn from industry case studies in heritage conservation (e.g., ICSC World Heritage reports on laser cleaning of carbonate stones)."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "unit": "%",
        "value": 60,
        "description": "Ensures uniform coverage; 30-50% for speed, 60-80% for thoroughness on irregular dolomite surfaces. 60% recommended to prevent gaps in cleaning. From process optimization studies in Lasers in Engineering journal for scanned beam cleaning of minerals."
      }
