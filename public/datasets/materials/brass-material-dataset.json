    "machineSettings": {
      "laserPower": {
        "description": "Optimal average power for Brass oxide removal without substrate damage",
        "unit": "W",
        "value": 100,
        "min": 1.0,
        "max": 120
      },
      "wavelength": {
        "description": "Near-IR wavelength for optimal Brass absorption and minimal reflectivity",
        "unit": "nm",
        "value": 1064,
        "min": 355,
        "max": 10640
      },
      "spotSize": {
        "min": 0.1,
        "max": 500,
        "value": 200,
        "unit": "μm",
        "description": "200-300 μm ideal for brass to achieve uniform cleaning on detailed surfaces; smaller for precision, larger for broad areas. Accounts for beam divergence on reflective surfaces. Source: Equipment specs from Coherent and Trumpf laser cleaning heads."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 30,
        "unit": "kHz",
        "description": "20-50 kHz balances speed and heat accumulation on reflective brass; higher rates (>50 kHz) risk overheating despite good conductivity. Source: Academic literature on pulsed laser cleaning (e.g., Appl. Surf. Sci. 2019), noting trade-offs for Cu-based alloys."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 10,
        "unit": "ns",
        "description": "Nanosecond regime preferred for cost-effective cleaning of brass; 10 ns minimizes heat-affected zone (HAZ) due to brass's thermal conductivity (~120 W/mK). Picosecond (<1 ns) for ultra-fine work but less common industrially. Source: Laser physics research in Opt. Lasers Eng. (2015) on metal ablation thresholds."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1500,
        "description": "Effective speeds balance cleaning efficiency and heat input; slower for heavy contamination (e.g., oxides), faster for light rust/oil. Recommended 1500 mm/s for uniform brass surface prep. Source: Industry standards from Laserax and academic studies on scan optimization (e.g., J. Laser Appl. 2018)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "1-3 passes typical for complete removal of contaminants on brass; multi-pass for layered dirt to stay below damage threshold. Single pass sufficient for light prep. Source: Industry case studies (e.g., Laser Cleaning Technol. reports) and practical optimization."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 70,
        "unit": "%",
        "description": "70% overlap ensures uniform coverage without excessive heat buildup on brass; higher for fine contaminants, lower for speed. Source: Process optimization studies in Surf. Coat. Technol. (2020) for scanned laser cleaning of metals."
      }
    }
