        "description": "Near-IR wavelength optimized for Silver's moderate reflectivity and thermal processing",
        "unit": "nm",
        "value": 1064,
        "min": 355,
        "max": 10640
      },
      "spotSize": {
        "min": 0.1,
        "max": 500,
        "unit": "μm",
        "value": 200,
        "description": "Beam diameter range for industrial cleaning; 200 μm recommended for silver to provide good resolution on detailed surfaces while covering larger areas efficiently; smaller for fine features, larger for broad preparation; per equipment specifications (e.g., CleanLaser CL series manuals)."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "unit": "kHz",
        "value": 50,
        "description": "Standard for pulsed laser cleaning; 50 kHz recommended for silver to enable fast processing while limiting heat buildup from pulse overlap; higher rates increase speed but risk thermal damage on reflective surfaces; trade-off noted in academic literature (e.g., Opt. Lasers Eng. reviews on pulse train effects)."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "value": 50,
        "description": "Nanosecond regime preferred for cost-effective cleaning of silver with low heat-affected zone (HAZ <10 μm); picosecond (ps) or femtosecond (fs) for ultra-precise applications but unnecessary for industrial contamination removal; ns avoids plasma shielding issues at 1064 nm; supported by laser physics research (e.g., J. Appl. Phys. studies on metal ablation)."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 2000,
        "description": "Effective speeds for contamination removal on silver; 2000 mm/s recommended for optimal balance of cleaning rate and minimal heat accumulation due to silver's high thermal conductivity (429 W/m·K); lower for heavy contamination, higher for light; from industry manuals (e.g., Adapt Laser Systems) and process optimization studies."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "unit": "passes",
        "value": 2,
        "description": "Typically 1-3 passes for light contamination on silver, up to 5 for heavy buildup; multi-pass (2 recommended) ensures complete removal without exceeding thermal limits; single pass possible for very light dirt; drawn from industry case studies (e.g., laser cleaning of cultural heritage silver artifacts in J. Cult. Herit.)."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "unit": "%",
        "value": 70,
        "description": "Standard overlap for uniform coverage in raster scanning; 70% recommended for silver to prevent streaking from high reflectivity and ensure even fluence distribution; lower (50%) for speed on large areas, higher (80%) for precision; from process optimization studies (e.g., Opt. Express on scan strategies for metals)."
      }
