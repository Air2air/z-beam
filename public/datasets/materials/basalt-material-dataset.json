      "spotSize": {
        "min": 0.1,
        "max": 500,
        "value": 200,
        "unit": "μm",
        "description": "Smaller spots (100-200 μm) for precise surface preparation on basalt, larger (300-500 μm) for broad area cleaning; recommended balances resolution and efficiency for industrial use. Source: Equipment specifications from Raycus and SPI Lasers; optimization in F. Léonard et al. (Opt. Lasers Eng., 2015) for heterogeneous surfaces like basalt."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 50,
        "unit": "kHz",
        "description": "Typical 20-80 kHz for effective contaminant removal; higher rates speed up cleaning but risk heat buildup on basalt's poor thermal dissipation. Trade-off favors moderate rates for uniform results. Source: Academic literature including R. N. Raman et al. (Opt. Express, 2010) on repetition rate effects in stone cleaning; manufacturer data from Trumpf lasers."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime (5-100 ns) preferred for basalt to achieve ablation with minimal heat-affected zone (HAZ); picosecond (ps) or femtosecond reduces HAZ further but increases cost. Recommended ns for industrial scalability and basalt's properties. Source: Laser physics research in A. Nevosad et al. (J. Appl. Phys., 2008) on pulsed laser cleaning of geological materials; avoids thermal cracking in low-conductivity basalt."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 500,
        "description": "Slower speeds (100-500 mm/s) for heavy contamination like rust or coatings on basalt, faster (1000-2000 mm/s) for light dirt; optimal balances cleaning efficiency and heat accumulation. Source: Industry standards from Laser Cleaning Europe guidelines and equipment manuals (e.g., Adapt Laser Systems); case studies in J. Pou et al. (Appl. Surf. Sci., 2011) for stone ablation."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, 2-3 for heavy layers on basalt to ensure complete removal without over-ablation; multi-pass minimizes damage risk. Source: Industry practice from case studies in heritage stone cleaning (adaptable to industrial), e.g., EN 17121 standard and reports by the European Laser Cleaning Association; practical trials in basalt quarrying applications."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 60,
        "unit": "%",
        "description": "30-50% for large areas to speed processing, 60-80% for uniform coverage and contaminant removal on textured basalt surfaces; prevents gaps in cleaning. Source: Process optimization studies in P. Pouli et al. (Appl. Phys. A, 2010) on scan strategies for stones; laser system manuals emphasizing overlap for even fluence distribution."
      }
