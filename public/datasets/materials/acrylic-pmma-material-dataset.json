        "description": "Standard for cleaning applications; 20 kHz recommended for PMMA to enable fast processing while minimizing heat buildup (higher rates increase accumulation risk). Trade-off: higher freq speeds cleaning but risks substrate damage. Source: Academic literature from Journal of Applied Physics on pulsed laser interactions with polymers."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime typical for industrial 1064 nm cleaning; picosecond (ps) or femtosecond preferred for minimal HAZ but less common. 20 ns recommended to reduce heat accumulation in PMMA. Source: Laser physics research in Optics & Laser Technology (e.g., studies on polymer ablation thresholds)."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 2000,
        "description": "Effective range for contaminant removal; slower (500-1500 mm/s) for heavy contamination, faster (2000-5000 mm/s) for light. Recommended 2000 mm/s balances speed and control for PMMA's low thermal conductivity. Source: Industry standards from Laserax equipment manuals."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass (2-5) for heavy; 2 passes recommended for complete PMMA cleaning without excessive exposure. Source: Industry case studies from laser cleaning applications in plastics processing (e.g., SPIE proceedings)."
      },
