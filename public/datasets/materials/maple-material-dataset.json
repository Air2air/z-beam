      "frequency": {
        "min": 1,
        "max": 200,
        "value": 50,
        "unit": "kHz",
        "description": "Standard for 1064 nm cleaning; higher rates (>50 kHz) speed up process but risk heat accumulation on low-thermal-conductivity maple. 50 kHz recommended for balance. Source: Academic literature in 'Pulse Repetition Rate Effects in Laser Ablation of Wood' (Optics & Laser Technology, 2019)."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 50,
        "unit": "ns",
        "description": "Nanosecond regime preferred for cost-effective cleaning of organics; picosecond (ps) reduces heat-affected zone but is less common for wood. 50 ns minimizes thermal damage to maple's low-conductivity structure. Source: Laser physics research in 'Ultrashort Pulse Lasers for Material Processing' (Applied Physics Reviews, 2020)."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1500,
        "description": "Effective speeds for contamination removal on wood; slower for heavy soiling (500-1000 mm/s), faster for light (2000-3000 mm/s). Recommended 1500 mm/s for optimal balance on maple. Source: Industry standards from Laserax equipment manuals; case studies in industrial surface prep."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass (2-5) for heavy; 2 passes recommended for complete removal on maple without excessive exposure. Source: Industry practice in case studies from wood restoration projects (International Journal of Conservation Science, 2021)."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 70,
        "unit": "%",
        "description": "Ensures uniform cleaning without gaps or over-ablation; 70% optimal for even coverage on irregular wood surfaces like maple. Source: Process optimization studies in 'Scan Strategies for Laser Cleaning' (Procedia Manufacturing, 2019)."
