    "machineSettings": {
      "laserPower": {
        "description": "Optimal average power for Hastelloy surface cleaning without substrate damage",
        "unit": "W",
        "value": 100,
        "min": 1.0,
        "max": 120
      },
      "wavelength": {
        "description": "Near-infrared wavelength optimized for Hastelloy absorption and minimal reflectivity",
        "unit": "nm",
        "value": 1064,
        "min": 355,
        "max": 10640
      },
      "spotSize": {
        "min": 0.1,
        "max": 500,
        "value": 200,
        "unit": "μm",
        "description": "Typical beam diameters for industrial cleaning; smaller (50-150 μm) for fine details, larger (200-500 μm) for broad surface prep on Hastelloy parts. 200 μm recommended for uniform energy distribution and efficiency on curved or large areas. Source: Equipment specifications from Adapt Laser Systems scanners; process guidelines in Industrial Laser Solutions (2019) for alloy cleaning."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 50,
        "unit": "kHz",
        "description": "Typical 10-200 kHz for pulsed cleaning; higher rates speed up process but increase heat accumulation on reflective Hastelloy (reflectivity ~65% at 1064 nm). 50 kHz balances speed and thermal management for contamination removal. Trade-off: >100 kHz risks overheating. Source: Academic literature in Optics Express (2017) on repetition rate optimization for metal cleaning; fiber laser specs from Coherent Inc."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime (5-200 ns) preferred for cost-effective cleaning; picosecond (ps) or femtosecond (fs) for ultra-low HAZ but less common industrially. 20 ns recommended for Hastelloy to limit thermal diffusion while ablating contaminants, reducing risk of microcracks in high-strength alloy. Source: Laser physics research in Applied Surface Science (2019) on pulse duration effects for Ni-superalloys; avoids fs due to high reflectivity at 1064 nm."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "value": 1000,
        "unit": "mm/s",
        "description": "Range for effective contaminant removal on reflective metals; slower speeds (200-800 mm/s) for heavy oxidation, faster (1000-3000 mm/s) for light surface prep. Recommended 1000 mm/s optimizes cleaning rate while minimizing heat input due to Hastelloy's thermal conductivity (~12 W/mK). Source: Industry standards from Laser CleanTech manuals; case studies in Journal of Laser Applications (2020) on superalloy surface preparation."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass (2-5) for heavy oxide or paint removal on Hastelloy. 2 passes recommended for complete cleaning while preserving surface integrity, allowing incremental fluence buildup. Source: Industry practice from case studies in Surface and Coatings Technology (2022) on superalloy prep; CleanLaser application notes for aerospace alloys."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 60,
        "unit": "%",
        "description": "Typical 30-80% for uniform coverage without gaps or overexposure; 60% recommended for Hastelloy to ensure even cleaning on irregular surfaces while minimizing total energy input and heat buildup. Higher overlap for heavy contamination. Source: Process optimization studies in Lasers in Manufacturing and Materials Processing (2020); scanning system manuals from Scanlab for metal applications."
      }
    }
