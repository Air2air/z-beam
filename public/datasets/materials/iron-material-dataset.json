    "machineSettings": {
      "laserPower": {
        "description": "Optimal average power for Iron oxide removal without substrate damage",
        "unit": "W",
        "value": 100,
        "min": 1.0,
        "max": 120
      },
      "wavelength": {
        "description": "Near-IR wavelength with good absorption in Iron oxides and minimal substrate damage",
        "unit": "nm",
        "value": 1064,
        "min": 355,
        "max": 10640
      },
      "spotSize": {
        "min": 0.1,
        "max": 500,
        "value": 200,
        "unit": "μm",
        "description": "Beam diameter range for industrial applications; smaller (100-200 μm) for precise surface prep on iron, larger for broad area cleaning. 200 μm recommended for uniform energy distribution on iron surfaces, avoiding hotspots. Source: Equipment specs from Raycus and Coherent lasers, per Journal of Laser Applications (2019)."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 30,
        "unit": "kHz",
        "description": "Common for pulsed cleaning of reflective metals like iron (reflectivity ~40-60% at 1064 nm); 30 kHz recommended for efficient pulse overlap without excessive heat accumulation, which could lead to oxidation. Higher rates speed up process but risk thermal buildup. Source: Academic review in Lasers in Manufacturing and Materials Processing (2021)."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 30,
        "unit": "ns",
        "description": "Nanosecond regime preferred for iron cleaning to provide sufficient energy for contaminant ablation with minimal thermal diffusion (due to iron's high conductivity ~80 W/m·K); picosecond (ps) or femtosecond reduces HAZ further but increases cost. 30 ns balances efficacy and safety. Source: Laser physics in Applied Surface Science (2019) on metal ablation thresholds."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 2000,
        "description": "Effective range for contamination removal on iron; higher speeds (e.g., 2000 mm/s) for light rust/oil, lower (500-1000 mm/s) for heavy oxides to ensure ablation without overheating. Recommended optimizes throughput while minimizing heat-affected zone (HAZ). Source: Industry standards from CleanLaser manuals and study in Journal of Cleaner Production (2020)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination (e.g., oils), multi-pass (2-3) for heavy rust on iron to achieve complete removal without increasing fluence. 2 passes recommended for industrial prep, allowing progressive cleaning. Source: Case studies in Industrial Laser Solutions (2020) and practical guidelines from laser cleaning consortia."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 70,
        "unit": "%",
        "description": "Ensures uniform coverage during scanning on iron; 70% recommended for even fluence distribution and to prevent gaps in cleaning, especially for irregular surfaces. Lower for faster processes, higher for thoroughness. Source: Process optimization in Applied Optics (2018) and manufacturer guidelines from Adapt Laser Systems."
      }
    }
