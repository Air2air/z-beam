      "frequency": {
        "min": 1,
        "max": 200,
        "unit": "kHz",
        "value": 40,
        "description": "Typical for pulsed cleaning; 40 kHz recommended for Poplar to balance speed and heat accumulation (Poplar's low reflectivity ~20% at 1064 nm aids absorption). Higher rates (>50 kHz) speed up but risk overheating. From academic lit. in Appl. Surf. Sci. (2019)."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "value": 20,
        "description": "Nanosecond regime preferred for Poplar to minimize heat-affected zone (HAZ <50 μm); picosecond (ps) reduces thermal damage further but increases cost. Avoid fs for industrial scale. Supported by laser physics in Opt. Express (2015) on wood ablation thresholds."
      },
