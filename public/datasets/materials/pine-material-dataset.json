      "frequency": {
        "min": 1,
        "max": 200,
        "value": 30,
        "unit": "kHz",
        "description": "Mid-range for effective contaminant vaporization on pine; higher rates increase speed but risk heat accumulation due to pine's poor conductivity, leading to discoloration. Trade-off favors moderate for safety. Source: Academic literature in Applied Surface Science (e.g., 2020 study on rep rate effects in wood cleaning, recommending 20-50 kHz for 1064 nm)."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime preferred over ps/fs for cost-effective cleaning of pine; shorter pulses minimize heat-affected zone (HAZ) to <50 μm, avoiding charring. Ps/fs for ultra-precision but overkill for industrial. Source: Laser physics research in Optics & Lasers in Engineering (e.g., 2018 review on pulsed laser ablation of wood at 1064 nm)."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1000,
        "description": "Slower speeds for heavy contamination on pine (e.g., resins or dirt), faster for light; optimal balances efficiency and heat dissipation given pine's low thermal conductivity (~0.12 W/mK). Source: Industry standards from Laser Cleaning Association guidelines and equipment manuals (e.g., CleanLaser systems, recommending 500-2000 mm/s for organics)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass for heavy (e.g., paint or rust on pine); 2 passes recommended to achieve complete removal while monitoring for thermal effects. Source: Industry practice in case studies from Laser Focus World (e.g., 2019 industrial wood prep examples) and operator manuals."
      },
