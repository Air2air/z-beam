      "frequency": {
        "min": 1,
        "max": 200,
        "value": 30,
        "unit": "kHz",
        "description": "Lower rates reduce heat accumulation in thermally sensitive alabaster; higher rates speed up cleaning but risk damage. 30 kHz recommended for effective contamination removal. Trade-off: high freq increases efficiency but elevates surface temp. Source: Academic literature, Appl. Surf. Sci. (2020) on pulsed laser cleaning of minerals."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime preferred for alabaster to minimize heat-affected zone (HAZ); picosecond (ps) or femtosecond for ultra-precision but less common industrially. 20 ns optimal for 1064 nm on low-conductivity materials like gypsum. Source: Laser physics research in Opt. Lasers Eng. (2015) on stone ablation."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1500,
        "description": "Slower speeds for heavy contamination on alabaster to ensure removal without substrate heating; faster for light dirt. Recommended 1500 mm/s for balance. Source: Industry standards from Laser Cleaning Europe guidelines and equipment manuals (e.g., CleanLaser systems)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Multi-pass for complete removal of heavy contamination on porous alabaster; single pass for light surface prep. 2 passes recommended to minimize total exposure time and heat buildup. Source: Industry practice in conservation case studies (e.g., ICLEA project reports on stone artifacts)."
      },
