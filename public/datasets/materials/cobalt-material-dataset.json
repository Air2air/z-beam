      "frequency": {
        "min": 1,
        "max": 200,
        "unit": "kHz",
        "value": 50,
        "description": "Standard for pulsed cleaning; higher rates speed up process but risk heat accumulation on reflective cobalt; 50 kHz optimal for controlled energy delivery. Trade-off: high freq increases throughput but requires monitoring temperature. Source: Academic literature in Applied Surface Science on metal cleaning parameters."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "value": 20,
        "description": "Nanosecond regime typical for industrial cleaning to ablate contaminants while minimizing HAZ on high-conductivity cobalt; picosecond (ps) or femtosecond (fs) for ultra-low heat but less common industrially. 20 ns recommended for balance. Source: Laser physics studies in Optics & Laser Technology (e.g., ns vs ps ablation thresholds)."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1500,
        "description": "Effective range for contamination removal; slower for heavy contaminants (e.g., oxides), faster for light; 1500 mm/s optimal for uniform cleaning without overheating. Source: CleanLaser equipment manuals and industry standards for 1064 nm cleaning."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "unit": "passes",
        "value": 2,
        "description": "Single pass for light contamination, multi-pass for heavy; 2 passes typical for complete removal on cobalt without excessive heat buildup. Source: Industry case studies in laser cleaning of aerospace alloys (e.g., similar to Co-based superalloys)."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "unit": "%",
        "value": 60,
        "description": "Ensures uniform coverage; 60% recommended for even cleaning on metallic surfaces like cobalt, avoiding gaps or overexposure. Range balances efficiency and homogeneity. Source: Process optimization in Surface & Coatings Technology journals."
