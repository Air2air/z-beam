        "value": 200,
        "description": "Smaller spots (100-300 μm) for fine detail on porcelain surfaces, larger (300-500 μm) for broad areas. Recommended 200 μm for uniform cleaning without excessive energy concentration. Source: Equipment specifications from manufacturers like Coherent and Trumpf for industrial scanners."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 20,
        "unit": "kHz",
        "description": "Typical 10-50 kHz for pulsed cleaning; higher rates speed up process but risk heat accumulation in porcelain's poor thermal dissipation. Recommended 20 kHz for safe, efficient removal without overheating. Trade-off: >30 kHz may require slower scans. Source: Academic literature on Q-switched lasers for ceramics (e.g., J. Appl. Phys. 2017)."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime preferred for 1064 nm cleaning of porcelain; picosecond (ps) or femtosecond (fs) for ultra-minimal HAZ but less common industrially due to cost. 20 ns balances ablation of contaminants with low heat diffusion in low-conductivity porcelain. Source: Laser physics research on ceramic ablation (e.g., Appl. Phys. A 2019)."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "value": 500,
        "unit": "mm/s",
        "description": "Typical speeds balance cleaning efficiency and heat input; slower (100-500 mm/s) for heavy contamination, faster (500-2000 mm/s) for light. Recommended 500 mm/s for porcelain to minimize exposure time and prevent cracking. Source: Industry standards from laser cleaning equipment manuals (e.g., IPG Photonics) and process optimization in Opt. Lasers Eng. 2020."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass (2-5) for heavy layers to build fluence gradually and avoid damage. Recommended 2 passes for porcelain in industrial prep. Source: Industry case studies on ceramic surface cleaning (e.g., Mater. Sci. Eng. B 2022)."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 70,
        "unit": "%",
        "description": "50-80% overlap ensures uniform coverage without gaps or over-ablation on brittle porcelain. Recommended 70% for optimal homogeneity in scan patterns. Source: Process optimization studies in laser scanning (e.g., Precis. Eng. 2019)."
