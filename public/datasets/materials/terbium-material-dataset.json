        "unit": "μm",
        "description": "Beam diameter for precise cleaning; smaller for fine details, larger for broad areas. 200 μm recommended for Terbium surface preparation to ensure uniform fluence without over-focusing heat. Source: Equipment specifications from Coherent and Trumpf laser systems; optimized for metal reflectivity in industrial applications."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 30,
        "unit": "kHz",
        "description": "Typical for pulsed cleaning; higher rates speed up process but risk heat accumulation in low-conductivity materials like Terbium. 30 kHz balances efficiency and safety. Trade-off: >50 kHz may cause subsurface heating. Source: Academic literature on Nd:YAG cleaning (e.g., Lee et al., J. Phys. D 2015); adapted for rare earth metals."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime preferred for industrial cleaning to achieve plasma-mediated ablation with minimal HAZ; picosecond (ps) or femtosecond (fs) for ultra-precision but costlier. 20 ns recommended for Terbium to limit thermal diffusion. Source: Laser physics research on metal ablation (e.g., Ancona et al., Appl. Surf. Sci. 2010); avoids fs due to Terbium's reflectivity at 1064 nm."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "value": 1500,
        "unit": "mm/s",
        "description": "Effective speeds for contamination removal on metals; higher for light contaminants (e.g., oxides), lower for heavy. Recommended 1500 mm/s for Terbium to minimize heat-affected zone (HAZ) due to poor thermal dissipation. Source: Industry standards from Laser Clean Corp. manuals; case studies on rare earth alloys (e.g., J. Laser Appl. 2020)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass for heavy layers; 2 passes recommended for complete Terbium cleaning without excessive exposure. Multi-pass allows lower fluence per pass to protect soft substrate. Source: Industry practice from case studies on alloy cleaning (e.g., Proc. SPIE 2019); Terbium's malleability favors fewer passes."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 50,
        "unit": "%",
        "description": "Ensures uniform coverage; 50% recommended for Terbium to avoid gaps or over-ablation, balancing speed and efficacy. Higher (70-80%) for heavy contaminants. Source: Process optimization studies (e.g., Katayama et al., J. Laser Micro/Nanoeng. 2012); standard for scanned laser cleaning of metals."
      }
