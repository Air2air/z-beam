    "machineSettings": {
      "laserPower": {
        "description": "Optimal average power for Rhodium surface cleaning without thermal damage",
        "unit": "W",
        "value": 45,
        "min": 1.0,
        "max": 120
      },
      "wavelength": {
        "description": "Near-IR wavelength optimized for Rhodium's moderate reflectivity and thermal absorption",
        "unit": "nm",
        "value": 1064,
        "min": 355,
        "max": 10640
      },
      "spotSize": {
        "min": 0.1,
        "max": 500,
        "unit": "μm",
        "value": 200,
        "description": "Smaller spots (50-200 μm) for fine surface preparation on Rhodium; larger (200-500 μm) for broad areas. 200 μm recommended for uniform cleaning without excessive overlap heating. Suited to Rhodium's use in plating/electronics. Source: Equipment specs from Coherent and Trumpf industrial lasers."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "unit": "kHz",
        "value": 50,
        "description": "Typical for pulsed cleaning to achieve high throughput; higher rates (50-100 kHz) speed up process but risk heat accumulation on reflective Rhodium. 50 kHz balances speed and safety. Trade-off: low freq reduces overlap heating. Source: Academic literature on Nd:YAG cleaning (e.g., J. Laser Appl. 2021)."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "value": 20,
        "description": "Nanosecond regime preferred for cost-effective cleaning of Rhodium; picosecond (ps) or femtosecond for ultra-minimal HAZ but less common industrially. 20 ns recommended to minimize heat-affected zone on high-melting-point Rhodium (1964°C). Avoid fs for industrial scale due to complexity. Source: Laser physics research in Appl. Phys. A 2019 on metal ablation thresholds."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 2000,
        "description": "Effective speeds for 1064 nm cleaning of metals; slower for heavy contamination (500-1000 mm/s), faster for light (3000-5000 mm/s). Recommended 2000 mm/s for Rhodium to ensure contaminant removal without substrate heating, considering its thermal conductivity (150 W/m·K). Source: Industry standards from Laserax equipment manuals and process optimization in Surf. Coat. Technol. 2020."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "unit": "passes",
        "value": 2,
        "description": "Single pass for light contamination; multi-pass (2-5) for heavy or uneven layers on Rhodium. Recommended 2 passes for complete removal while preserving substrate integrity. Based on industrial practice for precious metals. Source: Case studies in Ind. Laser Sol. 2019 and process reports from Adapt Laser Systems."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "unit": "%",
        "value": 60,
        "description": "Ensures uniform coverage without gaps or excessive energy input; 60% recommended for Rhodium to account for beam divergence and reflectivity, preventing uneven cleaning. Typical range from process optimization. Source: Studies in Laser Ablation and Surf. Eng. (Proc. SPIE 2020)."
      }
    }
