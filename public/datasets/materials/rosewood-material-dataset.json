      "frequency": {
        "min": 1,
        "max": 200,
        "value": 20,
        "unit": "kHz",
        "description": "Lower rates reduce heat accumulation in low-conductivity rosewood; higher rates speed up cleaning but increase burn risk. 20 kHz recommended for effective pulsed cleaning. Source: Academic literature on wood laser ablation (Applied Surface Science, 2020)."
