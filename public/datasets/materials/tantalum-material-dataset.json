        "description": "100-500 μm for fine detail cleaning on Tantalum components (e.g., implants); up to 1000 μm for large-area surface prep; 300 μm recommended for uniform energy distribution on reflective surfaces. Source: Equipment specifications from Trumpf and SPI Lasers for 1064 nm systems."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 50,
        "unit": "kHz",
        "description": "10-200 kHz typical for cleaning; lower rates reduce heat accumulation on heat-resistant Tantalum, higher speeds up process but risk overheating; 50 kHz recommended for efficient contamination removal without substrate damage. Trade-off: high freq increases throughput but requires cooling. Source: Academic literature in Journal of Laser Applications (2019)."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime (5-200 ns) preferred for industrial cleaning of Tantalum to ablate contaminants with minimal thermal diffusion due to its high thermal conductivity (57 W/m·K); picosecond (ps) or femtosecond (fs) for ultra-low HAZ but costlier; 20 ns recommended. Source: Laser physics research in 'Pulsed Laser Cleaning of Refractory Metals' (Applied Surface Science, 2015)."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1000,
        "description": "Slower speeds (100-500 mm/s) for heavy contamination to ensure complete removal; faster (up to 5000 mm/s) for light cleaning; 1000 mm/s recommended for optimal balance on Tantalum's conductive surface to minimize heat buildup. Source: Industry standards from Laser Institute of America guidelines and equipment manuals (e.g., Adapt Laser Systems)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination; 2-5 passes for heavy oxide or residue removal on Tantalum; 2 passes recommended to achieve complete cleaning without excessive heat exposure. Source: Industry case studies in aerospace applications (e.g., NASA reports on refractory metal processing, 2020)."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 50,
        "unit": "%",
        "description": "30-80% overlap ensures uniform coverage; 50% recommended for Tantalum to prevent gaps in cleaning while minimizing over-processing and heat accumulation on conductive surfaces. Source: Process optimization studies in 'Optimization of Laser Cleaning Parameters' (Surface and Coatings Technology, 2016)."
