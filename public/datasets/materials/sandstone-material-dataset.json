        "description": "Beam diameter range for industrial cleaning; 100-200 μm for fine detail on textured sandstone, 300-500 μm for large areas; 200 μm recommended for uniform energy distribution and control (source: Coherent/Trumpf equipment manuals; case studies in stone restoration)."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 30,
        "unit": "kHz",
        "description": "Common range for pulsed cleaning; 20-50 kHz recommended for sandstone to achieve fast coverage without excessive heat accumulation, trading off speed vs. thermal buildup in low-conductivity material (source: Pouli et al., 2015, Appl. Phys. A; academic studies on pulse overlap)."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "value": 15,
        "description": "Nanosecond regime (5-50 ns) typical for 1064 nm cleaning of stone; 15 ns recommended for minimal heat-affected zone (HAZ) on sandstone, reducing thermal diffusion; picosecond (ps) options (e.g., 10-100 ps) for ultra-precision but higher cost (source: Ancona et al., 2010, Opt. Express; laser physics reviews on ablation)."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "value": 1000,
        "unit": "mm/s",
        "description": "Effective range for contamination removal; slower (100-500 mm/s) for heavy soiling, faster (2000-5000 mm/s) for light; 1000 mm/s recommended for optimal balance on porous sandstone to prevent overheating (source: Industry guidelines from LaserClen systems; Asmus, 1995, Stud. Conserv.)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass (2-5) for heavy layers; 2 passes recommended for complete removal on sandstone without overexposure, allowing cooling between passes (source: Industry practice in heritage cleaning; Verges-Belmin, 2008, J. Cult. Herit.)."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 50,
        "unit": "%",
        "description": "Standard range for uniform coverage; 50% recommended for sandstone to ensure no gaps in porous surfaces while minimizing total energy input and heat buildup (source: Process optimization in laser scanning; Klein et al., 1999, J. Appl. Phys.)."
