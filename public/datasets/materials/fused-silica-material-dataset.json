      "frequency": {
        "min": 1,
        "max": 200,
        "unit": "kHz",
        "value": 50,
        "description": "Typical 20-80 kHz for cleaning; higher rates speed up process but risk heat accumulation on low-conductivity fused silica (melting point ~1700°C). Recommended 50 kHz balances speed and safety. Source: Academic literature in Optics and Lasers in Engineering (2021) discussing trade-offs in pulsed laser cleaning."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "description": "Nanosecond regime preferred for cost-effective cleaning; picosecond (ps) or femtosecond (fs) for ultra-minimal HAZ but higher cost. Typical 10-30 ns for fused silica to limit thermal diffusion given low thermal conductivity (~1.4 W/m·K). Recommended 20 ns. Source: Laser physics research in Applied Surface Science (2019) on pulse duration effects for dielectric materials.",
        "value": 500
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1500,
        "description": "Effective speeds balance cleaning efficiency and heat input; slower for heavy contamination (500-1000 mm/s), faster for light (2000-3000 mm/s). Recommended 1500 mm/s for uniform removal on fused silica. Source: Industry standards from Laser Cleaning Association guidelines and case studies in Journal of Applied Physics (2020)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "unit": "passes",
        "value": 2,
        "description": "Single pass for light contamination; multi-pass (2-3) for heavy layers to build fluence gradually without damage. Recommended 2 passes for fused silica industrial cleaning. Source: Industry practice in case studies from Surface and Coatings Technology (2022) on iterative laser processing."
      },
