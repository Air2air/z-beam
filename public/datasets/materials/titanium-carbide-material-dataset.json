      "frequency": {
        "min": 1,
        "max": 200,
        "value": 50,
        "unit": "kHz",
        "description": "Typical for 1064 nm cleaning to achieve uniform energy delivery on TiC; 50 kHz balances speed and heat management—higher rates risk accumulation on low-reflectivity TiC (~0.3-0.5 at 1064 nm). Trade-off: faster processing vs. potential overheating. Source: Academic literature in Optics Express (2017) on carbide ablation."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "value": 20,
        "description": "Nanosecond regime preferred for cost-effective cleaning of TiC with minimal HAZ due to its high thermal conductivity (~20-30 W/m·K); picosecond (ps) or femtosecond for ultra-precise but less common industrially. Avoids excessive heat accumulation. Source: Laser physics in 'Pulsed Laser Ablation of Ceramics' (Applied Surface Science, 2019)."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "value": 2000,
        "unit": "mm/s",
        "description": "Effective speeds for contamination removal on reflective/high-conductivity materials like TiC; higher for light contamination (up to 5000 mm/s), lower for heavy (500-1000 mm/s). Optimal balances fluence and coverage. Source: Industry standards from Laserax equipment manuals; case studies in Journal of Laser Applications (2020)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass (2-3) for heavy layers on TiC to ensure complete removal without substrate erosion. Recommended 2 passes for industrial prep. Source: Industry case studies in Surface and Coatings Technology (2019) for carbide tools."
      },
