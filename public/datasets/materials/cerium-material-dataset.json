      "frequency": {
        "min": 1,
        "max": 200,
        "value": 30,
        "unit": "kHz",
        "description": "Typical for Q-switched Nd:YAG lasers in cleaning; higher rates speed up process but risk heat accumulation on reflective, low-conductivity Cerium. 30 kHz balances speed and safety. Trade-off: high freq increases overlap heating. Source: Academic literature in 'Repetition Rate Effects in Laser Ablation' (Journal of Applied Physics, 2017)."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 20,
        "unit": "ns",
        "description": "Nanosecond regime preferred for industrial cleaning to ablate contaminants without deep substrate penetration; picosecond (ps) or femtosecond for ultra-minimal HAZ but costlier. 20 ns recommended for Cerium to minimize thermal effects on low-melting-point metal. Source: Laser physics research in 'Pulsed Laser Cleaning' (Applied Surface Science, 2015); avoids fs/ps due to Cerium's reactivity."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 500,
        "description": "Range for effective cleaning of metallic surfaces; slower for heavy contamination, faster for light. Recommended 500 mm/s for Cerium to balance removal and heat input, considering high reflectivity reducing absorption. Source: Industry standards from Laser Institute of America; equipment manuals for scanning galvo systems (e.g., CleanLaser CL 50)."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass for heavy; 2 passes recommended for complete Cerium cleaning to avoid excessive heat per pass, given low melting point. Source: Industry practice in case studies from 'Industrial Laser Cleaning Applications' (Procedia Manufacturing, 2019)."
      },
      "overlapRatio": {
        "min": 10,
