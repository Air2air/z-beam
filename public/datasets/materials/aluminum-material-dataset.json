        "description": "Beam diameter range for uniform coverage; smaller for fine details, larger for broad areas. 300 μm recommended for aluminum to achieve even fluence distribution without hotspots. Source: Equipment specifications from Coherent and Trumpf laser cleaners, with optimization in Surface and Coatings Technology (2019)."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 50,
        "unit": "kHz",
        "description": "Typical for pulsed fiber lasers at 1064 nm; higher rates speed up cleaning but risk heat accumulation on reflective aluminum. 50 kHz balances speed and safety. Source: Academic literature in Lasers in Manufacturing and Materials Processing (2021) on frequency effects for aluminum surface preparation."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "value": 50,
        "unit": "ns",
        "description": "Nanosecond regime preferred for cost-effective industrial cleaning; picosecond (ps) or femtosecond reduces HAZ but increases cost. 50 ns recommended for aluminum to ablate contaminants with minimal thermal diffusion. Source: Laser physics research in Applied Surface Science (2019) comparing pulse regimes for metals."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 1500,
        "description": "Effective speeds for light to heavy contamination on aluminum; slower for heavy (e.g., oxide layers), faster for light oils. Recommended 1500 mm/s optimizes removal while minimizing heat buildup due to aluminum's conductivity. Source: Industry standards from Laserax equipment manuals and Journal of Cleaner Production (2020) case studies."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass for heavy; aluminum's reflectivity often requires 2 passes for complete removal without damage. Source: Industry practice in case studies from Journal of Laser Applications (2020) on industrial aluminum cleaning."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 70,
        "unit": "%",
        "description": "Ensures uniform coverage and prevents gaps in cleaning; 70% recommended for aluminum to account for beam divergence and material reflectivity. Source: Process optimization studies in International Journal of Advanced Manufacturing Technology (2018)."
