      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Multi-pass (2 recommended) for complete removal of layered contaminants without exceeding thermal limits; single pass sufficient for light soils on tempered glass. Source: Industry practice in Laser Cleaning Handbook (2022) and case studies from glass manufacturing (e.g., Pilkington reports)."
