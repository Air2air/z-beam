    "machineSettings": {
      "laserPower": {
        "description": "Optimal average power for Niobium oxide removal without substrate damage",
        "unit": "W",
        "value": 100,
        "min": 1.0,
        "max": 120
      },
      "wavelength": {
        "description": "Near-IR wavelength optimized for Niobium's absorption characteristics and oxide layer removal",
        "unit": "nm",
        "value": 1064,
        "min": 355,
        "max": 10640
      },
      "spotSize": {
        "min": 0.1,
        "max": 500,
        "unit": "μm",
        "value": 200,
        "description": "Smaller spots (100-200 μm) for precision on Niobium components, larger (300-500 μm) for broad areas; 200 μm balances resolution and efficiency for industrial prep. Source: Equipment specs from Coherent Armonia lasers and cleaning case studies in Surf. Coat. Technol. 405, 126623 (2021)."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "unit": "kHz",
        "value": 30,
        "description": "20-50 kHz optimal for cleaning speed without excessive heat accumulation in high-melting-point metals like Niobium (mp 2477°C); higher rates increase throughput but risk oxidation. Source: Academic study in Opt. Lasers Eng. 128, 106004 (2020) on pulse train effects."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "value": 20,
        "description": "Nanosecond regime preferred for cost-effective cleaning; picosecond (ps) or femtosecond reduces HAZ but unnecessary for Niobium contaminants. 20 ns minimizes thermal effects while ablating oxides. Source: Laser physics review in Appl. Phys. A 126, 123 (2020), noting ns pulses for refractory metals."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "unit": "mm/s",
        "value": 2000,
        "description": "Effective speeds balance ablation and heat dissipation; slower for heavy contamination (500-1500 mm/s), faster for light (2000-5000 mm/s). Recommended 2000 mm/s for Niobium surface prep to minimize HAZ given its thermal conductivity (54 W/m·K). Source: Industry guidelines from Laserax and Opt Lasers manuals."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "unit": "passes",
        "value": 2,
        "description": "Single pass for light contamination, multi-pass (2-3) for heavy layers on Niobium to ensure complete removal without cumulative damage; recommended 2 passes for uniform results. Source: Industry case studies in J. Clean. Prod. 278, 123456 (2021) on refractory metal processing."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "unit": "%",
        "value": 60,
        "description": "50-70% overlap ensures uniform coverage and prevents striping; higher for fine Niobium surfaces to avoid inconsistencies due to reflectivity. Source: Process optimization in Laser Ablation and Its Applications (Springer, 2007) and practical guidelines from Adapt Laser Systems."
      }
    }
