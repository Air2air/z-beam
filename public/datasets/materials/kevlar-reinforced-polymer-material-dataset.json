      "spotSize": {
        "min": 0.1,
        "max": 500,
        "value": 200,
        "unit": "μm",
        "description": "Smaller spots for precision on textured Kevlar surfaces, larger for broad areas; 100-300 μm for fine cleaning, 300-500 μm for large-scale prep. 200 μm recommended to match Kevlar weave (~100-200 μm fibers) and ensure even fluence. Source: Equipment specs from Coherent Inc.; process opt. in Lasers Manuf. Mater. Process. (2020)."
      },
      "frequency": {
        "min": 1,
        "max": 200,
        "value": 30,
        "unit": "kHz",
        "description": "Lower rates reduce heat accumulation in heat-sensitive Kevlar; high rates (>50 kHz) speed cleaning but risk substrate damage. 30 kHz balances speed and safety for contamination removal. Trade-off: higher freq increases throughput but elevates surface temp. Source: Academic lit. in J. Clean. Prod. (2021) on pulsed laser parameters for polymers."
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "value": 20,
        "description": "Nanosecond regime preferred for cost-effective cleaning with minimal HAZ; picosecond (ps) or femtosecond reduces thermal effects but increases cost. 20 ns optimal for Kevlar to limit heat diffusion in low-conductivity matrix. Avoid >100 ns to prevent melting (~450°C decomposition). Source: Laser physics in Appl. Phys. A (2019) on aramid composites."
      },
      "scanSpeed": {
        "min": 10,
        "max": 5000,
        "value": 1000,
        "unit": "mm/s",
        "description": "Effective speeds balance cleaning efficiency and heat input; slower for heavy contamination (500-1000 mm/s), faster for light (2000-3000 mm/s). Recommended 1000 mm/s for uniform removal on Kevlar without fiber disruption. Source: Industry standards from Laserax manuals; Opt. Lasers Eng. (2020) case studies on polymer ablation."
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, multi-pass (2-5) for stubborn residues; 2 passes typical for Kevlar to achieve complete removal without cumulative heat damage. Multi-pass allows lower fluence per pass. Source: Industry practice in case studies from Adapt Laser Systems; J. Mater. Process. Technol. (2019)."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 60,
        "unit": "%",
        "description": "Ensures uniform coverage without gaps or over-ablation; 30-50% for fast scans, 60-80% for thorough cleaning on irregular Kevlar surfaces. 60% recommended for even contaminant removal while minimizing total energy input. Source: Process optimization in Opt. Laser Technol. (2021); standards from scanning system manuals like Scanlab."
      }
