    "machineSettings": {
      "laserPower": {
        "min": 50,
        "max": 500,
        "value": 100,
        "unit": "W",
        "description": "Typical range for 1064 nm pulsed lasers in industrial cleaning of delicate substrates like soda-lime glass to remove contaminants without thermal damage; starting at 100 W for controlled ablation. Max limited to avoid heat accumulation given glass's low thermal conductivity (~1 W/m·K). Source: Manufacturer specs from IPG Photonics and Coherent for YAG lasers; academic review in 'Laser Cleaning' by Kononenko et al. (Optics and Lasers in Engineering, 2016)."
      },
      "wavelength": {
        "description": "Near-IR wavelength optimized for Soda-Lime Glass absorption and minimal subsurface damage",
        "unit": "nm",
        "value": 1064,
        "min": 355,
        "max": 10640
      },
      "spotSize": {
        "description": "Beam spot diameter for precise cleaning with adequate energy density",
        "unit": "μm",
        "value": 100,
        "min": 0.1,
        "max": 500
      },
      "frequency": {
        "description": "Optimal repetition rate for efficient cleaning coverage and thermal management",
        "unit": "kHz",
        "value": 50,
        "min": 1,
        "max": 200
      },
      "pulseWidth": {
        "min": 0.1,
        "max": 1000,
        "unit": "ns",
        "value": 20,
        "description": "Nanosecond regime (5-100 ns) preferred for cost-effective cleaning with sufficient peak power for contaminant ejection; picosecond (ps) or femtosecond (fs) reduce heat-affected zone (HAZ) but are overkill for most industrial glass cleaning due to transparency at 1064 nm. Recommended 20 ns minimizes thermal diffusion in glass (melting point ~500°C). Source: Laser physics research in Applied Surface Science (e.g., Palmieri et al., 2019) on ns vs. ps for dielectrics."
      },
      "scanSpeed": {
        "description": "Scan velocity for effective cleaning with controlled thermal input",
        "unit": "mm/s",
        "value": 1150,
        "min": 10,
        "max": 5000
      },
      "passCount": {
        "min": 1,
        "max": 10,
        "value": 2,
        "unit": "passes",
        "description": "Single pass for light contamination, up to 5 for heavy layers; multi-pass preferred for glass to distribute energy and avoid damage. Recommended 2 passes for complete removal in industrial settings. Source: Industry practice from case studies in Surface and Coatings Technology (e.g., 2014 paper on glass cleaning) and manufacturer guidelines (e.g., Lasertec)."
      },
      "overlapRatio": {
        "min": 10,
        "max": 90,
        "value": 50,
        "unit": "%",
        "description": "Typical 30-80% for uniform coverage without gaps or over-exposure; 50% recommended for soda-lime glass to ensure even cleaning while minimizing total energy input and potential thermal stress. Source: Process optimization studies in Lasers in Manufacturing and Materials Processing (2019) and industry standards from SPIE proceedings on scan strategies."
      }
