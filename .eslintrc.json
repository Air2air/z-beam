{
  "extends": [
    "next/core-web-vitals",
    "next/typescript"
  ],
  "rules": {
    // Type safety - strategic approach
    "@typescript-eslint/no-explicit-any": "off",  // Suppressed: 600+ warnings, requires systematic refactoring
    "@typescript-eslint/no-unused-vars": ["warn", { 
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^_",
      "caughtErrorsIgnorePattern": "^_"
    }],
    "@typescript-eslint/no-require-imports": "warn",
    "prefer-const": "error",
    "react/no-unescaped-entities": "off",  // Suppressed: JSX entities handled by Prettier
    "no-console": "off",  // Allowed in development
    
    // Architecture enforcement - prevent deprecated imports
    "no-restricted-imports": ["error", {
      "patterns": [{
        "group": ["../**/app/**", "../../app/**", "../../../app/**"],
        "message": "Use @/ path aliases instead of relative imports for app directory"
      }, {
        "group": ["../**/types/**", "../../types/**"],
        "message": "Use @/types instead of relative imports for types"
      }, {
        "group": ["@/utils/constants", "../utils/constants", "../../utils/constants"],
        "message": "Import from @/config instead. SITE_CONFIG has been moved to app/config/site.ts"
      }, {
        "group": ["@/utils/business-config", "../utils/business-config"],
        "message": "Import BUSINESS_CONFIG from @/config instead. File is deprecated."
      }]
    }],
    
    // Code quality rules - relaxed for pragmatic development
    "complexity": "off",  // Suppressed: Complex business logic exists by necessity
    "max-lines-per-function": "off",  // Suppressed: Some React components naturally large
    "max-depth": "off",  // Suppressed: Nested logic acceptable when clear
    
    // Naming conventions enforcement
    "@typescript-eslint/naming-convention": ["error",
      {
        "selector": "interface",
        "format": ["PascalCase"],
        "custom": {
          "regex": "^I[A-Z]",
          "match": false
        }
      },
      {
        "selector": "typeAlias",
        "format": ["PascalCase"]
      },
      {
        "selector": "variable",
        "modifiers": ["const"],
        "format": ["UPPER_CASE", "camelCase", "PascalCase"],
        "leadingUnderscore": "allow"
      },
      {
        "selector": "variable",
        "format": ["camelCase", "PascalCase"],
        "leadingUnderscore": "allow"
      },
      {
        "selector": "function",
        "format": ["camelCase", "PascalCase"],
        "leadingUnderscore": "allow",
        "filter": {
          "regex": "^(GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS)$",
          "match": false
        }
      },
      {
        "selector": "function",
        "filter": {
          "regex": "^(GET|POST|PUT|PATCH|DELETE|HEAD|OPTIONS)$",
          "match": true
        },
        "format": ["UPPER_CASE"]
      },
      {
        "selector": "parameter",
        "format": ["camelCase", "PascalCase"],
        "leadingUnderscore": "allow"
      },
      {
        "selector": "parameter",
        "format": ["camelCase", "snake_case", "PascalCase"],
        "leadingUnderscore": "allow",
        "filter": {
          "regex": "^(research_library|material_challenges|page_description|Icon|IconComponent)$",
          "match": true
        }
      },
      {
        "selector": "property",
        "filter": {
          "regex": "^(loading|disabled|visible|hidden|enabled|active|selected|checked|required|valid|open|closed)$",
          "match": true
        },
        "format": []
        // These properties are exempt from is/has/can prefix requirement
      },
      {
        "selector": "variable",
        "format": ["camelCase", "snake_case", "PascalCase", "UPPER_CASE"],
        "leadingUnderscore": "allow",
        "filter": {
          "regex": "^(meta_description|contamination_description|page_description)$",
          "match": true
        }
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/app/config/site.ts",
        "**/app/datasets/**/*.ts",
        "**/app/utils/frontmatterValidation.ts",
        "**/app/utils/errorSystem.ts",
        "**/app/utils/metadata/**/*.ts"
      ],
      "rules": {
        "@typescript-eslint/naming-convention": "warn"
      }
    },
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts"],
      "rules": {
        "max-lines-per-function": "off",
        "@typescript-eslint/no-explicit-any": "off",
        "no-console": "off"
      }
    },
    {
      "files": ["scripts/**/*.js", "scripts/**/*.ts"],
      "rules": {
        "no-console": "off",
        "max-lines-per-function": "off"
      }
    }
  ]
}
