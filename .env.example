# Environment Variables Template
# Copy this file to .env.local and configure your values

# Next.js Configuration
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
NEXT_PUBLIC_VERCEL_URL=

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=
VERCEL_ANALYTICS_ID=

# Calendly Booking
# Get your booking URL from: https://calendly.com/event_types/user/me
# Format: https://calendly.com/your-username/event-type
NEXT_PUBLIC_CALENDLY_URL=

# Content Management
CONTENT_API_KEY=
CONTENT_SECRET=

# External Services
EXTERNAL_API_URL=
EXTERNAL_API_KEY=

# Google Workspace Email (Gmail SMTP)
# Your Gmail/Google Workspace email address
GMAIL_USER=info@yourdomain.com
# Generate an App Password at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=

# Security
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Development
NODE_ENV=development
