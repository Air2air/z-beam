# Environment Variables for Z-Beam Contact Form

# Analytics and Ads
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-TZF55CB5XC
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-1007895174
NEXT_PUBLIC_GOOGLE_ADS_THANK_YOU_CONVERSION_LABEL=

# Resend Email Service
# Get your API key from: https://resend.com/api-keys
