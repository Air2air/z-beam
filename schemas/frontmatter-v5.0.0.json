# YAML Schema for Material/Contaminant/Settings Frontmatter
# Version: 5.0.0

$schema: http://json-schema.org/draft-07/schema#
$id: https://z-beam.com/schemas/frontmatter-v5.0.0.json

definitions:
  # Common definitions
  author:
    type: object
    required: [id, name, country, email]
    properties:
      id: { type: integer }
      name: { type: string }
      country: { type: string }
      country_display: { type: string }
      title: { type: string }
      sex: { type: string, enum: [m, f, nb] }
      jobTitle: { type: string }
      expertise: { type: array, items: { type: string } }
      affiliation:
        type: object
        properties:
          name: { type: string }
          type: { type: string }
      credentials: { type: array, items: { type: string } }
      email: { type: string, format: email }
      image: { type: string }
      imageAlt: { type: string }
      url: { type: string, format: uri }
      sameAs: { type: array, items: { type: string, format: uri } }
      persona_file: { type: string }
      formatting_file: { type: string }

  breadcrumb_item:
    type: object
    required: [label, href]
    properties:
      label: { type: string }
      href: { type: string }

  image_object:
    type: object
    required: [url, alt]
    properties:
      url: { type: string }
      alt: { type: string }
      width: { type: integer }
      height: { type: integer }

  machine_parameter:
    type: object
    required: [description, unit, value]
    properties:
      description: { type: string }
      unit: { type: string }
      value: { type: number }
      min: { type: number }
      max: { type: number }

  machine_settings:
    type: object
    required: [powerRange, wavelength, spotSize, repetitionRate, energyDensity, pulseWidth, scanSpeed, passCount]
    properties:
      powerRange: { $ref: '#/definitions/machine_parameter' }
      wavelength: { $ref: '#/definitions/machine_parameter' }
      spotSize: { $ref: '#/definitions/machine_parameter' }
      repetitionRate: { $ref: '#/definitions/machine_parameter' }
      energyDensity: { $ref: '#/definitions/machine_parameter' }
      pulseWidth: { $ref: '#/definitions/machine_parameter' }
      scanSpeed: { $ref: '#/definitions/machine_parameter' }
      passCount: { $ref: '#/definitions/machine_parameter' }
      overlapRatio: { $ref: '#/definitions/machine_parameter' }

  # Relationship Section Metadata (MANDATORY for all sections)
  relationship_section_metadata:
    type: object
    required: [sectionTitle, sectionDescription, icon, order]
    properties:
      sectionTitle:
        type: string
        minLength: 1
        description: "Display title for the section"
      sectionDescription:
        type: string
        minLength: 1
        description: "Brief description of section content"
      icon:
        type: string
        minLength: 1
        description: "Lucide-react icon identifier"
      order:
        type: integer
        minimum: 1
        maximum: 999
        description: "Sort order for section display"
      variant:
        type: string
        enum: [default, warning, info, success]
        description: "Visual variant for styling"
      collapsible:
        type: boolean
        description: "Whether section can be collapsed"
      defaultExpanded:
        type: boolean
        description: "Whether section starts expanded"

  # Relationship Section Data Structure
  relationship_section:
    type: object
    required: [presentation, items, _section]
    properties:
      presentation:
        type: string
        enum: [card, badge, descriptive, table]
        description: "Presentation type for section data"
      items:
        type: array
        minItems: 0
        description: "Array of data items (structure varies by section type)"
      _section:
        $ref: '#/definitions/relationship_section_metadata'
        description: "Required metadata for all relationship sections"

# Main schema types
type: object
required: [id, name, datePublished, dateModified, content_type, schema_version, fullPath, breadcrumb, author]

properties:
  id:
    type: string
    pattern: "^[a-z0-9-]+$"
    description: "Lowercase slug identifier"

  name:
    type: string
    minLength: 1
    description: "Display name of the material/contaminant/setting"

  datePublished:
    type: string
    format: date-time
    description: "ISO 8601 date-time"

  dateModified:
    type: string
    format: date-time
    description: "ISO 8601 date-time"

  content_type:
    type: string
    enum: [unified_material, unified_contamination, settings]
    description: "Type of content page"

  schema_version:
    type: string
    pattern: "^\\d+\\.\\d+\\.\\d+$"
    description: "Semantic version number"

  fullPath:
    type: string
    pattern: "^/"
    description: "Full URL path"

  breadcrumb:
    type: array
    minItems: 1
    items:
      $ref: '#/definitions/breadcrumb_item'

  author:
    $ref: '#/definitions/author'

  # Content fields
  micro:
    type: string
    minLength: 10
    maxLength: 500
    description: "Micro description (short summary)"

  subtitle:
    type: string
    minLength: 10
    maxLength: 200
    description: "Page subtitle"

  description:
    type: string
    minLength: 10
    maxLength: 5000
    description: "Main description"

  # Images
  images:
    type: object
    properties:
      hero: { $ref: '#/definitions/image_object' }
      micro: { $ref: '#/definitions/image_object' }

  # Machine settings (for settings content type)
  machine_settings:
    $ref: '#/definitions/machine_settings'

  # Relationships (v5.0 - Structured sections with metadata)
  relationships:
    type: object
    description: "Structured relationship sections with mandatory _section metadata"
    properties:
      # Operational category
      operational:
        type: object
        properties:
          industry_applications:
            $ref: '#/definitions/relationship_section'
            description: "Industries using this material/contaminant"
          laser_properties:
            $ref: '#/definitions/relationship_section'
            description: "Laser-material interaction data"
          removal_difficulty:
            $ref: '#/definitions/relationship_section'
            description: "Difficulty ratings for contaminant removal"
          compatible_materials:
            $ref: '#/definitions/relationship_section'
            description: "Materials compatible with this setting"
          application_scenarios:
            $ref: '#/definitions/relationship_section'
            description: "Use cases and application scenarios"
      
      # Safety category
      safety:
        type: object
        properties:
          regulatory_standards:
            $ref: '#/definitions/relationship_section'
            description: "Applicable safety and compliance standards"
          exposure_limits:
            $ref: '#/definitions/relationship_section'
            description: "Safety exposure thresholds (OSHA, NIOSH)"
          ppe_requirements:
            $ref: '#/definitions/relationship_section'
            description: "Required protective equipment"
          health_hazards:
            $ref: '#/definitions/relationship_section'
            description: "Health risks from exposure"
      
      # Interactions category
      interactions:
        type: object
        properties:
          contaminated_by:
            $ref: '#/definitions/relationship_section'
            description: "Contaminants affecting this material"
          produces_compounds:
            $ref: '#/definitions/relationship_section'
            description: "Hazardous compounds created during cleaning"
          found_on_materials:
            $ref: '#/definitions/relationship_section'
            description: "Materials where this contaminant appears"
      
      # Physical category
      physical:
        type: object
        properties:
          visual_characteristics:
            $ref: '#/definitions/relationship_section'
            description: "Observable material properties"
          physical_properties:
            $ref: '#/definitions/relationship_section'
            description: "Measurable material properties"
      
      # Technical category
      technical:
        type: object
        properties:
          chemical_properties:
            $ref: '#/definitions/relationship_section'
            description: "Chemical composition and reactivity"
    
    # Allow additional categories and sections
    additionalProperties:
      type: object
      additionalProperties:
        $ref: '#/definitions/relationship_section'

  # Challenges
  challenges:
    type: object
    properties:
      thermal_management:
        type: array
        items:
          type: object
          required: [challenge, severity, impact, solutions]
          properties:
            challenge: { type: string }
            severity: { type: string, enum: [low, medium, high, critical] }
            property_value: { type: string }
            threshold_range: { type: string }
            impact: { type: string }
            solutions: { type: array, items: { type: string } }

      surface_characteristics:
        type: array
        items:
          type: object
          required: [challenge, severity, impact, solutions]
          properties:
            challenge: { type: string }
            severity: { type: string, enum: [low, medium, high, critical] }
            reflectivity_range: { type: string }
            impact: { type: string }
            solutions: { type: array, items: { type: string } }

      contamination_challenges:
        type: array
        items:
          type: object
          required: [challenge, severity, impact, solutions]
          properties:
            challenge: { type: string }
            severity: { type: string, enum: [low, medium, high, critical] }
            impact: { type: string }
            solutions: { type: array, items: { type: string } }

  # Component summaries
  component_summaries:
    type: object
    properties:
      machine_settings:
        type: object
        properties:
          title: { type: string }
          description: { type: string }
      material_safety_heatmap:
        type: object
        properties:
          title: { type: string }
          description: { type: string }

# Conditional validation based on content_type
if:
  properties:
    content_type:
      const: settings
then:
  required: [machine_settings]
  properties:
    machine_settings:
      $ref: '#/definitions/machine_settings'
