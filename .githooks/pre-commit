#!/bin/sh

# Pre-commit hook to enforce component reusability rules
# This prevents commits that violate component duplication rules

echo "🛡️  Pre-commit: Checking component reusability rules..."

# Run the component enforcement check
if ! node enforce-component-rules.js; then
    echo ""
    echo "💥 COMMIT BLOCKED: Component reusability violations found!"
    echo ""
    echo "🔧 To fix:"
    echo "1. Run './quick-audit.sh' to see violations"
    echo "2. Replace hardcoded implementations with shared components"
    echo "3. Review REQUIREMENTS.md section 2 for guidance"
    echo ""
    echo "⚠️  To bypass this check (NOT RECOMMENDED):"
    echo "   git commit --no-verify"
    echo ""
    exit 1
fi

echo "✅ Pre-commit: Component reusability rules passed!"
exit 0
