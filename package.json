{
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:analyze": "cross-env ANALYZE=true next build",
    "build:production": "NODE_ENV=production next build",
    "start": "next start",
    "lint": "next lint --fix",
    "type-check": "tsc --noEmit",
    "ci": "npm run predeploy && npm run build",
    "ci:full": "npm run type-check && npm run lint && npm run predeploy && npm run build",
    "clean": "rm -rf .next node_modules/.cache",
    "test": "node tests/test-typescript-build.js",
    "test:components": "node tests/test-component-validation.js",
    "test:warnings": "node tests/test-warning-cleanup.js",
    "test:autofix": "node tests/test-auto-fix-suite.js",
    "test:vercel": "node tests/test-vercel-optimization.js",
    "predeploy": "npm run test:comprehensive && npm run test:autofix && node tests/predeploy-vercel-check.js && npm run predeploy:summary",
    "test:all": "npm run test && npm run test:components && npm run test:warnings && echo '🎉 All tests completed!'",
    "test:comprehensive": "npm run test:all && npm run test:vercel && npm run test:yaml && npm run test:layout && npm run test:content && echo '🚀 Comprehensive testing completed!'",
    "test:yaml": "node tests/test-yaml-errors.js",
    "test:layout": "node tests/test-layout-structure.js",
    "test:content": "node tests/test-content-validation.js",
    "predeploy:summary": "node tests/predeploy-summary.js",
    "cleanup": "node cleanup/test-dead-file-cleanup.js",
    "cleanup:warnings": "./cleanup/automated-warning-cleanup.sh",
    "cleanup:restore": "./cleanup/automated-warning-cleanup.sh restore",
    "yaml:validate": "cd yaml-processor && ./yaml --validate ../content --verbose",
    "yaml:fix": "cd yaml-processor/tools && python3 yaml_common_fixes.py ../../content/components/frontmatter",
    "analyze": "cross-env ANALYZE=true next build"
  },
  "dependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.0.9",
    "geist": "^1.3.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "marked": "^16.1.1",
    "next": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.89.2",
    "typescript": "5.3.3"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "react-is": "^18.3.1",
    "loose-envify": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/js-yaml": "^4.0.9",
    "autoprefixer": "^10.4.21",
    "eslint": "8.x.x",
    "eslint-config-next": "15.x.x",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "5.x.x"
  }
}