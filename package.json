{
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --fix",
    "type-check": "tsc --noEmit",
    "ci": "npm run type-check && npm run lint && npm run build",
    
    "clean": "rm -rf .next node_modules/.cache",
    "kill-port": "lsof -ti:3000 | xargs kill -9 || true",
    
    "test": "node cleanup/test-runner.js",
    "test:components": "node tests/test-component-validation.js",
    "test:coverage": "node tests/coverage-runner.js",
    "test:coverage:view": "cat tests/coverage-report.json | jq '.' || cat tests/coverage-report.json",
    "test:typescript": "node tests/test-typescript-build.js",
    "test:all": "npm run test && npm run test:components && npm run test:coverage && echo '🎉 All tests and coverage analysis completed!'",
    "test:quick": "npm run test --silent && echo '✅ Quick tests passed'",
    "cleanup": "./cleanup/cleanup-dead-files.sh",
    "cleanup:analyze": "node cleanup/test-dead-file-cleanup.js",
    
    "yaml:validate": "cd yaml-processor && ./yaml --validate ../content --verbose",
    "yaml:fix": "cd yaml-processor/tools && python3 yaml_common_fixes.py ../../content/components/frontmatter",
    "yaml:monitor": "cd yaml-processor && ./yaml-monitor.sh --watch",
    
    "deploy:staging": "gh workflow run deploy.yml -f environment=staging",
    "deploy:prod": "gh workflow run deploy.yml -f environment=production"
  },
  "dependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.0.9",
    "geist": "^1.3.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "marked": "^16.1.1",
    "next": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.89.2",
    "typescript": "5.3.3"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "react-is": "^18.3.1",
    "loose-envify": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/js-yaml": "^4.0.9",
    "autoprefixer": "^10.4.21",
    "eslint": "8.x.x",
    "eslint-config-next": "15.x.x",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "5.x.x"
  }
}
