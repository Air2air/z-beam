{
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "clean": "rm -rf .next node_modules/.cache tsconfig.tsbuildinfo .vercel",
    "lint": "eslint app/ --ext .ts,.tsx",
    "lint:fix": "eslint app/ --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:fix": "node tests/jest-test-fixer.js && npm run test",
    "predeploy": "node streamlined-predeploy.js",
    "validate:production": "node production-build-validator.js",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "deploy:local": "npm run predeploy && npm run build && echo '✅ Local deployment validation complete'",
    "vercel-build": "npm run predeploy && next build",
    "validate": "npm run type-check && npm run lint && npm run test && npm run build",
    "fix": "npm run lint:fix && npm run type-check"
  },
  "dependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.0.9",
    "geist": "^1.3.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "marked": "^16.1.1",
    "next": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.89.2",
    "typescript": "5.3.3",
    "tailwindcss": "^3.4.17",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "react-is": "^18.3.1",
    "loose-envify": "^1.4.0",
    "picomatch": "^2.3.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "eslint": "8.x.x",
    "eslint-config-next": "15.x.x",
    "jest": "^30.0.5",
    "ts-jest": "^29.4.1",
    "typescript": "5.x.x"
  }
}
