{
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:safe": "./scripts/dev/safe-start.sh",
    "dev:persistent": "./scripts/dev/start-dev-persistent.sh",
    "dev:status": "./scripts/dev/check-dev-status.sh",
    "dev:restart": "./scripts/dev/restart-dev-server.sh",
    "dev:detect": "./scripts/dev/detect-runaway-processes.sh",
    "dev:stop-all": "./scripts/dev/stop-all-processes.sh",
    "dev:cleanup": "./scripts/dev/auto-cleanup-processes.sh",
    "dev:watch": "./scripts/dev/watch-processes.sh",
    "dev:health": "./scripts/dev/health-check.sh",
    "validate:breadcrumbs": "tsx scripts/validate-breadcrumbs.ts",
    "migrate:breadcrumbs": "tsx scripts/migrate-breadcrumbs.ts",
    "migrate:breadcrumbs:dry-run": "tsx scripts/migrate-breadcrumbs.ts --dry-run",
    "prebuild": "npm run validate:frontmatter && npm run validate:naming && npm run validate:metadata && npm run verify:sitemap && npm run validate:jsonld && npm run validate:breadcrumbs && npm run generate:datasets",
    "build": "next build && npm run postbuild",
    "postbuild": "npm run validate:urls",
    "build:fast": "next build",
    "generate:datasets": "tsx scripts/generate-datasets.ts",
    "analyze": "ANALYZE=true npm run build",
    "start": "next start",
    "clean": "rm -rf .next node_modules/.cache tsconfig.tsbuildinfo .vercel",
    "cleanup:root": "node scripts/cleanup-root.js",
    "lint": "eslint app/ --ext .ts,.tsx",
    "lint:fix": "eslint app/ --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "validate": "npm run validate:metadata && npm run type-check && npm run lint && npm run test:ci && npm run build",
    "validate:metadata": "node scripts/validate-metadata-sync.js",
    "validate:metadata:verbose": "node scripts/validate-metadata-sync.js --verbose",
    "validate:naming": "node scripts/validate-naming-e2e.js",
    "deploy": "./scripts/deployment/smart-deploy.sh deploy",
    "deploy:prod": "./scripts/deployment/smart-deploy.sh deploy",
    "deploy:monitor": "./scripts/deployment/smart-deploy.sh deploy-monitor",
    "monitor": "./scripts/deployment/smart-deploy.sh monitor",
    "cleanup": "node scripts/automated-cleanup.js",
    "cleanup:dry-run": "node scripts/automated-cleanup.js --dry-run",
    "logs": "vercel logs --follow",
    "status": "vercel ls",
    "vercel-build": "npm run validate:metadata && next build",
    "test:ci": "jest --coverage --watchAll=false --passWithNoTests",
    "test:debug": "jest --detectOpenHandles --forceExit",
    "test:unit": "jest tests/utils --coverage=false",
    "test:integration": "jest tests/integration",
    "test:components": "jest tests/components",
    "test:parsing": "node tests/test-parsing-standardization.js",
    "test:content": "node tests/test-content-validation.js",
    "test:images": "jest tests/image-naming-conventions.test.js",
    "test:comprehensive": "npm run test:parsing && npm run test:content && npm run test:images && npm run test:ci",
    "test:deployment": "jest --config jest.deployment.config.js",
    "test:deployment:config": "jest tests/deployment/deployment-config.test.ts",
    "test:deployment:watch": "jest --config jest.deployment.config.js --watch",
    "test:sitemap": "jest tests/sitemap/sitemap.test.ts --coverage=false",
    "verify:sitemap": "bash scripts/sitemap/verify-sitemap.sh",
    "validate:fast": "npm run type-check && npm run test:unit",
    "validate:deployment": "npm run type-check && npm run test:deployment && npm run build",
    "validate:frontmatter": "node scripts/validate-frontmatter-structure.js",
    "validate:urls": "node scripts/validate-jsonld-urls.js",
    "validate:redirects": "node scripts/validate-redirects.js",
    "precommit": "npm run validate:fast",
    "deploy:health": "node scripts/deployment/health-check.js",
    "deploy:history": "node scripts/deployment/deployment-history.js list",
    "deploy:stats": "node scripts/deployment/deployment-history.js stats",
    "deploy:analyze": "node scripts/deployment/analyze-deployment-error.js",
    "setup:hooks": "bash scripts/deployment/setup-auto-monitor.sh && chmod +x scripts/hooks/pre-commit.sh && ln -sf ../../scripts/hooks/pre-commit.sh .git/hooks/pre-commit",
    "validate:grok": "node scripts/buildValidation.ts",
    "validate:grok:strict": "node scripts/buildValidation.ts --strict",
    "audit:components": "node scripts/componentAudit.ts",
    "validate:startup": "node -e \"const {startupValidator} = require('./app/utils'); startupValidator.validateSystem().then(r => console.log('Startup validation:', r.passed ? 'PASS' : 'FAIL')).catch(e => {console.error('Startup validation failed:', e); process.exit(1);})\"",
    "validate:content": "node -e \"const {contentValidator} = require('./app/utils'); contentValidator.validateAllContent().then(r => console.log('Content validation:', r.passed ? 'PASS' : 'FAIL', `(${r.errors.length} errors, ${r.warnings.length} warnings)`)).catch(e => {console.error('Content validation failed:', e); process.exit(1);})\"",
    "validate:jsonld": "jest tests/architecture/jsonld-enforcement.test.ts --verbose --coverage=false",
    "validate:jsonld:live": "node scripts/test-jsonld-live.js",
    "validate:jsonld:comprehensive": "node scripts/validate-jsonld-comprehensive.js",
    "validate:all": "npm run validate:naming && npm run validate:metadata && npm run validate:startup && npm run validate:content && npm run validate:grok && npm run validate:jsonld && npm run audit:components",
    "pagespeed": "node scripts/pagespeed-audit.js https://z-beam.com",
    "pagespeed:mobile": "node scripts/pagespeed-audit.js https://z-beam.com mobile",
    "pagespeed:desktop": "node scripts/pagespeed-audit.js https://z-beam.com desktop",
    "update-freshness": "node scripts/update-freshness-timestamps.js",
    "update-freshness:execute": "node scripts/update-freshness-timestamps.js --execute",
    "update-freshness:weekly": "node scripts/update-freshness-timestamps.js --execute --batch=25 --oldest",
    "verify:freshness": "bash scripts/verify-freshness-integration.sh",
    "setup:freshness": "bash scripts/setup-freshness-hooks.sh"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "@tailwindcss/typography": "^0.5.16",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "autoprefixer": "^10.4.21",
    "geist": "^1.5.1",
    "google-auth-library": "^10.4.2",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "marked": "^16.1.1",
    "next": "^14.2.18",
    "nodemailer": "^7.0.9",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "resend": "^6.1.0",
    "sass": "^1.89.2",
    "server-only": "^0.0.1",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.1"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "react-is": "^18.3.1",
    "loose-envify": "^1.4.0",
    "picomatch": "^2.3.1"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@babel/plugin-transform-class-properties": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/plugin-transform-runtime": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@next/bundle-analyzer": "^16.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/nodemailer": "^7.0.2",
    "@types/yargs": "^17.0.33",
    "@types/yargs-parser": "^21.0.3",
    "babel-jest": "^30.1.2",
    "critters": "^0.0.23",
    "eslint": "8.x.x",
    "eslint-config-next": "15.x.x",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.0.5",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.1.2",
    "typescript": "^5.9.3"
  }
}
