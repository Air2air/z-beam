{
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:fast": "npm run kill-port || true && next dev -p 3000",
    "dev:direct": "next dev -p 3000",
    "ready": "next -v",
    "webpack:check": "next -v",
    "webpack:repair": "rm -rf .next",
    "webpack:force": "rm -rf .next node_modules/.cache",
    "kill-port": "lsof -ti:3000 | xargs kill -9",
    "build": "next build",
    "build:skip-check": "next build",
    "start": "next start",
    "enforce-components": "node enforce-component-rules.js",
    "lint:components": "npm run enforce-components",
    "create:component": "node safe-component-creation.js",
    
    "# YAML Processing System": "# Scripts for processing and validating YAML frontmatter",
    "yaml:process": "cd yaml-processor && python3 yaml_processor.py ../content /Users/todddunning/Desktop/Z-Beam/z-beam-generator/validators/examples --verbose --timeout 10",
    "yaml:check": "cd yaml-processor && python3 yaml_validator.py ../content --verbose --timeout 10",
    "yaml:completeness": "cd yaml-processor && python3 yaml_validator.py ../content --verbose --required-fields name,description,applications,technicalSpecifications",
    "yaml:materials-check": "cd yaml-processor && python3 yaml_validator.py ../content/components/frontmatter --verbose --required-fields name,description,properties,applications,technicalSpecifications",
    "yaml:test": "python3 -m unittest tests/test_yaml_validator.py",
    "yaml:check-file": "cd yaml-processor/tools && python3 check_file_completeness.py",
    
    "# Maintenance Scripts": "# Scripts for project maintenance and cleanup",
    "cleanup:archive": "./archive-cleanup.sh",
    "docs:validate": "echo 'Validating documentation files...' && find docs -name '*.md' -type f -exec echo 'Checking {}' \\;",
    
    "lint": "next lint --fix",
    "type-check": "tsc --noEmit",
    "deploy:staging": "gh workflow run deploy.yml -f environment=staging",
    "deploy:prod": "gh workflow run deploy.yml -f environment=production",
    "ci": "npm run type-check && npm run lint && npm run build",
    "kill": "lsof -ti tcp:3000 | xargs kill"
  },
  "dependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.0.9",
    "geist": "^1.3.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "marked": "^16.1.1",
    "next": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.89.2",
    "typescript": "5.3.3"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "react-is": "^18.3.1",
    "loose-envify": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/js-yaml": "^4.0.9",
    "autoprefixer": "^10.4.21",
    "eslint": "8.x.x",
    "eslint-config-next": "15.x.x",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "5.x.x"
  }
}
