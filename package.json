{
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' tsx scripts/dev/validate-frontmatter-on-startup.ts && next dev",
    "dev:persistent": "./scripts/dev/start-persistent.sh",
    "dev:bg": "npm run dev > /tmp/z-beam-dev.log 2>&1 & echo $! > /tmp/z-beam-dev.pid && echo 'Dev server starting in background (PID saved to /tmp/z-beam-dev.pid)'",
    "dev:logs": "tail -f /tmp/z-beam-dev.log",
    "dev:stop": "[ -f /tmp/z-beam-dev.pid ] && kill $(cat /tmp/z-beam-dev.pid) && rm /tmp/z-beam-dev.pid && echo 'Dev server stopped' || echo 'No dev server PID file found'",
    "dev:status": "lsof -ti:3000 > /dev/null && echo '✅ Dev server is running on port 3000' || echo '❌ Dev server is not running'",
    "dev:health": "npm run dev:status && curl -fsS http://localhost:3000 >/dev/null && echo '✅ Dev server HTTP health check passed' || (echo '❌ Dev server HTTP health check failed' && exit 1)",
    "dev:restart": "npm run dev:stop && sleep 1 && npm run dev:persistent",
    "dev:stop-all": "pkill -f 'next dev' 2>/dev/null || true; lsof -ti:3000 | xargs kill -9 2>/dev/null || true; rm -f /tmp/z-beam-dev.pid .dev-server.pid; echo '✅ Stopped all dev server processes'",
    "prebuild": "npm run type-check && npm run lint:all && npm run validate:content && npm run validate:naming:semantic && npm run validate:types && npm run verify:sitemap:links && npm run test:seo:comprehensive && npm run test:ci",
    "build": "next build && npm run generate:sitemaps",
    "vercel-build": "npm run build",
    "start": "next start",
    "clean": "rm -rf .next node_modules/.cache tsconfig.tsbuildinfo .vercel .validation-cache",
    "check": "node scripts/validation/lib/run-checks.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint app/ --ext .ts,.tsx",
    "lint:all": "next lint",
    "component-audit": "next lint --dir app/components",
    "enforce-components": "npm run component-audit && npm run type-check",
    "lint:fix": "eslint app/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "test": "jest",
    "test:unit": "jest tests/utils tests/lib --coverage=false",
    "test:integration": "jest tests/integration --coverage=false",
    "test:components": "jest tests/components --coverage=false",
    "test:seo": "jest tests/seo --coverage=false",
    "test:seo:comprehensive": "jest tests/seo/comprehensive-seo-infrastructure.test.ts --verbose",
    "test:seo:article": "jest tests/seo/article-schema.test.ts tests/seo/product-schema.test.ts tests/seo/howto-schema.test.ts",
    "test:seo:metadata": "jest tests/seo/*-validation.test.ts --coverage=false",
    "test:seo:rich-results": "jest tests/seo/rich-results.test.ts",
    "test:seo:all": "jest tests/seo --coverage --verbose",
    "test:all": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --watchAll=false --passWithNoTests",
    "validate:content": "node scripts/validation/lib/run-content-validation.js",
    "validate:frontmatter": "node scripts/validation/content/validate-frontmatter-structure.js",
    "validate:metadata": "node scripts/validation/content/validate-metadata-sync.js",
    "validate:naming": "node scripts/validation/content/validate-naming-e2e.js",
    "validate:naming:semantic": "node scripts/validation/validate-semantic-naming.js",
    "validate:types": "node scripts/validation/validate-type-imports.js",
    "validate:breadcrumbs": "tsx scripts/validation/content/validate-breadcrumbs.ts",
    "migrate:breadcrumbs": "tsx scripts/migrate-breadcrumbs.ts",
    "migrate:seo": "tsx scripts/migrate-seo-metadata.ts",
    "validate:seo": "npm run validate:seo-infrastructure && npm run test:seo:comprehensive",
    "validate:seo-infrastructure": "node scripts/validation/seo/validate-seo-infrastructure.js",
    "validate:seo:comprehensive": "npm run test:seo:all && npm run validate:seo-infrastructure",
    "validate:seo:lighthouse": "node scripts/validation/seo/validate-lighthouse-metrics.js",
    "validate:seo:richness": "node scripts/validation/jsonld/validate-schema-richness.js",
    "validate:performance": "node scripts/validation/seo/validate-core-web-vitals.js",
    "validate:a11y": "node scripts/validation/accessibility/validate-wcag-2.2.js",
    "validate:urls": "node scripts/validation/jsonld/validate-jsonld-urls.js",
    "validate:schemas:live": "node scripts/validation/validate-schemas-live.js",
    "validate:production": "node scripts/validation/post-deployment/validate-production.js",
    "validate:production:simple": "node scripts/validation/post-deployment/validate-production-simple.js",
    "validate:production:enhanced": "node scripts/validation/post-deployment/validate-production-enhanced.js",
    "validate:production:comprehensive": "node scripts/validation/post-deployment/validate-production-comprehensive.js",
    "validate:production:strict-seo": "node scripts/validation/post-deployment/validate-production-comprehensive.js --strict-seo --require-rich-results",
    "validate:production:parity": "node scripts/validation/post-deployment/validate-production-comprehensive.js --strict-seo --require-rich-results --compare-url=$COMPARE_URL",
    "validate:production:full": "node scripts/validation/post-deployment/validate-production-comprehensive.js --skip-external",
    "validate:production:complete": "node scripts/validation/post-deployment/run-all-validations.js",
    "validate:all": "npm run validate:content && npm run validate:seo-infrastructure && npm run validate:a11y && npm run validate:performance",
    "validate:seo:advanced": "npm run seo:entity-map && npm run seo:featured-snippets && npm run seo:core-web-vitals",
    "validate:seo:esoteric": "npm run seo:delta-sitemap && npm run seo:crawl-budget && npm run seo:canonical-graph && npm run seo:entity-graph && npm run seo:soft404-orphans",
    "validate:seo:esoteric:soft": "MAX_URLS=120 STRICT_MODE=0 npm run seo:delta-sitemap && MAX_URLS=120 STRICT_MODE=0 npm run seo:crawl-budget && MAX_URLS=120 STRICT_MODE=0 npm run seo:canonical-graph && MAX_URLS=120 STRICT_MODE=0 npm run seo:entity-graph && MAX_URLS=120 STRICT_MODE=0 npm run seo:soft404-orphans && MAX_URLS=120 STRICT_MODE=0 npm run seo:bot-logs && MAX_URLS=120 STRICT_MODE=0 npm run seo:serp-monitor",
    "validate:jsonld:syntax": "echo '⚠️  DEPRECATED: Use validate:seo-infrastructure instead' && exit 1",
    "validate:jsonld:rendering": "echo '⚠️  DEPRECATED: Use validate:seo-infrastructure instead' && exit 1",
    "postbuild": "npm run validate:urls && npm run validate:seo:advanced",
    "postdeploy": "node scripts/validation/post-deployment/run-all-validations.js",
    "build:analyze": "ANALYZE=true npm run build",
    "verify:sitemap": "bash scripts/sitemap/verify-sitemap.sh",
    "verify:sitemap:links": "NODE_ENV=production tsx scripts/sitemap/verify-links.ts",
    "analyze:sitemap": "NODE_ENV=production tsx scripts/sitemap/analyze-sitemap.ts",
    "generate:image-sitemap": "node seo/scripts/generate-image-sitemap.js",
    "generate:sitemap-index": "node seo/scripts/generate-sitemap-index.js",
    "generate:sitemaps": "npm run generate:image-sitemap && npm run generate:sitemap-index",
    "seo:help": "cat seo/README.md | head -100",
    "seo:test": "npm test tests/seo/image-seo.test.ts",
    "seo:report": "node -e \"const fs = require('fs'); const report = JSON.parse(fs.readFileSync('seo/analysis/performance-reports/2025-12-28-snapshot.json', 'utf8')); console.log('SEO Score:', report.summary.seoScore + '%', '(' + report.summary.grade + ')'); console.log('Mobile:', report.mobile.performance, 'Desktop:', report.desktop.performance); console.log('Images:', report.imageSEO.totalImages, 'with alt text'); console.log('Tests:', report.tests.total + '/' + report.tests.total, 'passing')\"",
    "seo:validate": "npm run validate:seo-infrastructure && npm test tests/seo/",
    "seo:featured-snippets": "node seo/scripts/analyze-featured-snippets.js",
    "seo:entity-map": "node seo/scripts/entity-mapper.js",
    "seo:contextual-links": "node seo/scripts/contextual-linker.js",
    "seo:core-web-vitals": "node seo/scripts/analyze-core-web-vitals.js",
    "seo:delta-sitemap": "node scripts/seo/advanced/generate-delta-sitemap.js",
    "seo:indexnow": "node scripts/seo/advanced/submit-indexnow.js",
    "seo:crawl-budget": "node scripts/seo/advanced/validate-crawl-budget-policy.js",
    "seo:canonical-graph": "node scripts/seo/advanced/analyze-canonical-graph.js",
    "seo:soft404-orphans": "node scripts/seo/advanced/detect-soft404-orphans.js",
    "seo:entity-graph": "node scripts/seo/advanced/validate-entity-graph-consistency.js",
    "seo:bot-logs": "node scripts/seo/advanced/analyze-bot-logs.js",
    "seo:serp-monitor": "node scripts/seo/advanced/monitor-serp-trends.js",
    "seo:optimize": "npm run seo:entity-map && npm run seo:contextual-links && npm run seo:featured-snippets && npm run seo:core-web-vitals",
    "deploy": "bash scripts/deployment/deploy.sh",
    "deploy:monitored": "node scripts/deployment/deploy-monitored.js",
    "test:propertybars": "jest tests/components/PropertyBars.test.tsx --coverage=false",
    "test:layout": "jest tests/components/Layout.test.tsx --coverage=false",
    "deploy:preview": "vercel",
    "cache:clear": "rm -rf .validation-cache",
    "cache:stats": "node -e \"const ValidationCache = require('./scripts/validation/lib/cache'); console.log(ValidationCache.getStats());\"",
    "logs:view": "ls -lht .terminal-logs/**/*.log 2>/dev/null | head -20 || echo 'No logs yet'",
    "logs:clean": "find .terminal-logs -name '*.log' -mtime +7 -delete 2>/dev/null && echo '✅ Old logs cleaned' || echo 'No old logs to clean'",
    "logs": "vercel logs --follow",
    "status": "vercel ls"
  },
  "dependencies": {
    "@builder.io/partytown": "^0.10.3",
    "@jest/globals": "^30.2.0",
    "@next/third-parties": "^16.0.1",
    "@tailwindcss/typography": "^0.5.16",
    "@types/marked": "^5.0.2",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "autoprefixer": "^10.4.21",
    "geist": "^1.5.1",
    "glob": "^11.0.3",
    "google-auth-library": "^10.4.2",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "jsdom": "^27.3.0",
    "lucide-react": "^0.553.0",
    "marked": "^16.1.1",
    "next": "^14.2.18",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "sass": "^1.89.2",
    "server-only": "^0.0.1",
    "tailwindcss": "^3.4.17",
    "web-vitals": "^5.1.0",
    "xml2js": "^0.6.2",
    "yaml": "^2.8.2"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "react-is": "^18.3.1",
    "loose-envify": "^1.4.0",
    "picomatch": "^2.3.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/yargs": "^17.0.33",
    "@types/yargs-parser": "^21.0.3",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "axe-core": "^4.11.0",
    "baseline-browser-mapping": "^2.9.19",
    "chrome-launcher": "^1.2.1",
    "critters": "^0.0.23",
    "dotenv": "^17.2.3",
    "eslint": "8.x.x",
    "eslint-config-next": "15.x.x",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.2.0",
    "lighthouse": "^13.0.1",
    "puppeteer": "^24.29.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
