{
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:prod": "NODE_ENV=production next build",
    "start": "next start",
    "clean": "rm -rf .next node_modules/.cache tsconfig.tsbuildinfo",
    "check": "npm run type-check && npm run lint",
    "type-check": "tsc --noEmit",
    "lint": "next lint --fix",
    "test": "node tests/test-auto-fix-suite.js",
    "test:full": "npm run check && node tests/test-auto-fix-suite.js && node tests/predeploy-vercel-check.js",
    "fix": "node tests/fix-any-types-safe.js",
    "deploy": "npm run test:full && npm run build:prod",
    "analyze": "cross-env ANALYZE=true next build"
  },
  "dependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.0.9",
    "geist": "^1.3.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "marked": "^16.1.1",
    "next": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.89.2",
    "typescript": "5.3.3"
  },
  "overrides": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "react-is": "^18.3.1",
    "loose-envify": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/js-yaml": "^4.0.9",
    "autoprefixer": "^10.4.21",
    "eslint": "8.x.x",
    "eslint-config-next": "15.x.x",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "5.x.x"
  }
}